---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config/site';
import { dmy } from '../../lib/format';
import { HERO_CLASS_MAP } from '../../lib/labels';

type Char = { name: string; image?: string; element?: string; desc?: string; role?: string };
type Tier = { label: string; sublabel?: string; color?: string; chars: Char[] };

export async function getStaticPaths() {
  function parseTiers(body: string): Tier[] {
    try {
      const arr = JSON.parse((body || '').trim() || '[]');
      return Array.isArray(arr) ? arr : [];
    } catch {
      return [];
    }
  }
  const tierlists = await getCollection('tierlists');
  return tierlists.map((t) => ({
    params: { game: t.id },
    props: {
      meta: t.data,
      tiers: parseTiers(t.body ?? ''),
      gameId: t.id,
      others: tierlists
        .filter((o) => o.id !== t.id)
        .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
        .map((o) => ({ slug: o.id, label: o.data.game_label, updated: o.data.updated ? dmy(o.data.updated) : '' })),
    },
  }));
}

const { meta, tiers, gameId, others } = Astro.props;
const img = (file?: string) => (file ? `/tierlists/${gameId}/images/${file}` : null);
const initials = (name: string) => name.split(/\s+/).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
---

<BaseLayout title={`Tier-List ${meta.game_label}`} activeNav="tier" description={`Tier-list ${meta.game_label} — hover nhân vật để xem chi tiết.`}>
  <div class="page-head">
    <div class="crumb">TRANG CHỦ / <a href="/tier-list">TIER-LIST</a> / <span class="here">{meta.game_label.toUpperCase()}</span></div>
    <div class="page-head-row">
      <div>
        <div class="page-title">{meta.game_label}</div>
        {meta.genre && <div class="genre">{meta.genre}</div>}
      </div>
      <div class="page-meta">{meta.version ? `BẢN ${meta.version} · ` : ''}{meta.updated ? `CẬP NHẬT ${dmy(meta.updated)}` : ''}</div>
    </div>
    {meta.blurb && <p class="blurb">{meta.blurb}</p>}
  </div>

  <section class="gut tl-layout">
    <div class="tl-table">
      <div class="tl-hint">HOVER NHÂN VẬT ĐỂ XEM HỆ & GIỚI THIỆU</div>
      {tiers.map((tier) => (
        <div class="tier-row">
          <div class="tier-badge" style={`background:${tier.color || '#888'}`}>
            <span class="tb-label">{tier.label}</span>
            {tier.sublabel && <span class="tb-sub">{tier.sublabel}</span>}
          </div>
          <div class="tier-track">
            {tier.chars.length === 0
              ? <span class="tier-empty">—</span>
              : tier.chars.map((c) => (
                  <div class="avatar" tabindex="0" role="button"
                    data-name={c.name} data-img={img(c.image) ?? ''} data-el={c.element ?? ''} data-desc={c.desc ?? ''} data-class={c.role && HERO_CLASS_MAP[c.role] ? HERO_CLASS_MAP[c.role].icon : ''}>
                    {img(c.image)
                      ? <img src={img(c.image)} alt={c.name} loading="lazy" />
                      : <span class="abbr">{initials(c.name)}</span>}
                    <span class="cap">{c.name}</span>
                  </div>
                ))}
          </div>
        </div>
      ))}
      {tiers.length === 0 && <p class="tier-empty" style="padding:30px 0">Chưa có dữ liệu tier. Thêm trong CMS.</p>}
    </div>

    <aside class="tl-side">
      {others.length > 0 && (
        <div class="others">
          <div class="side-head">◆ TIER-LIST GAME KHÁC</div>
          <div class="other-list">
            {others.map((o) => (
              <a class="other-item" href={`/tier-list/${o.slug}`}>
                <span class="oi-name">{o.label}</span>
                <span class="oi-date">{o.updated}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      <a class="discord" href={SITE.socials.discord} target="_blank" rel="noopener">
        <div class="dc-title">Không đồng ý với xếp hạng?</div>
        <div class="dc-sub">Vào Discord tranh luận cùng cộng đồng Cenix.</div>
        <div class="dc-cta">JOIN DISCORD →</div>
      </a>
    </aside>
  </section>

  <div class="tl-popup" id="tl-popup" hidden>
    <div class="pop-class" id="pop-class"></div>
    <div class="pop-top">
      <div class="pop-ava" id="pop-ava"></div>
      <div class="pop-id">
        <div class="pop-name" id="pop-name"></div>
        <div class="pop-el" id="pop-el"></div>
      </div>
    </div>
    <div class="pop-desc" id="pop-desc"></div>
  </div>
</BaseLayout>

<style>
  .genre { font: 400 11px var(--mono); color: var(--lime); margin-top: 8px; letter-spacing: 1px; }
  .blurb { font: 400 12.5px/1.6 var(--display); color: var(--tx-dim); margin: 16px 0 0; max-width: 640px; }
  .tl-layout { padding-top: 36px; padding-bottom: 44px; display: grid; grid-template-columns: 1fr 300px; gap: 28px; }
  .tl-hint { font: 400 10px var(--mono); color: var(--tx-meta); margin-bottom: 12px; letter-spacing: 1px; }

  .tier-row { display: flex; gap: 0; align-items: stretch; border: 1px solid var(--bd-soft); border-bottom: none; }
  .tier-row:last-child { border-bottom: 1px solid var(--bd-soft); }
  .tier-badge { width: 92px; flex: none; color: #0a0a0b; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; padding: 14px 6px; }
  .tb-label { font: 900 30px/1 var(--display); }
  .tb-sub { font: 700 9px var(--mono); letter-spacing: 0.5px; }
  .tier-track { flex: 1; background: var(--surface-2); padding: 12px; display: flex; gap: 12px; flex-wrap: wrap; min-height: 96px; align-content: flex-start; }
  .tier-empty { font: 400 11px var(--mono); color: var(--tx-faint); align-self: center; }

  .avatar { position: relative; width: 72px; flex: none; cursor: pointer; text-align: center; }
  .avatar > img, .avatar .abbr { width: 72px; height: 72px; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; object-fit: cover; background: repeating-linear-gradient(45deg, #1c1c22 0, #1c1c22 8px, #202028 8px, #202028 16px); outline: 2px solid transparent; outline-offset: 2px; transition: outline-color 0.15s; }
  .avatar .abbr { font: 700 12px var(--mono); color: var(--tx-55); }
  .avatar:hover > img, .avatar:hover .abbr, .avatar.on > img, .avatar.on .abbr { outline-color: var(--lime); }
  .avatar .cap { display: block; margin-top: 6px; font: 700 10px/1.2 var(--display); color: var(--tx-65); }
  .avatar:hover .cap { color: #fff; }

  .tl-side { display: flex; flex-direction: column; gap: 26px; }
  .side-head { font: 900 12px var(--mono); letter-spacing: 2px; color: var(--lime); border-bottom: 1px solid var(--bd-card); padding-bottom: 10px; margin-bottom: 4px; }
  .other-list { display: flex; flex-direction: column; }
  .other-item { display: flex; justify-content: space-between; align-items: center; padding: 13px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.07); color: #fff; }
  .other-item:last-child { border-bottom: none; }
  .other-item .oi-name { font: 700 13px var(--display); }
  .other-item:hover .oi-name { color: var(--lime); }
  .other-item .oi-date { font: 400 9px var(--mono); color: var(--tx-faint); }
  .discord { border: 1px solid var(--lime-40); border-radius: 3px; padding: 20px; background: linear-gradient(160deg, rgba(200, 240, 60, 0.07), transparent 65%); display: block; color: #fff; }
  .dc-title { font: 800 15px/1.3 var(--display); margin-bottom: 6px; }
  .dc-sub { font: 400 10.5px/1.55 var(--mono); color: var(--tx-55); margin-bottom: 14px; }
  .dc-cta { background: var(--lime); color: var(--on-lime); font: 700 10.5px var(--mono); padding: 9px; border-radius: 2px; text-align: center; }

  .tl-popup { position: absolute; z-index: 50; width: 260px; background: var(--popup); border: 1px solid rgba(200, 240, 60, 0.5); border-radius: 4px; padding: 14px; box-shadow: 0 12px 40px rgba(0, 0, 0, 0.7); }
  .pop-top { display: flex; gap: 12px; margin-bottom: 8px; align-items: center; padding-right: 26px; }
  .pop-ava { width: 48px; height: 48px; flex: none; border-radius: 3px; overflow: hidden; background: repeating-linear-gradient(45deg, #1c1c22 0, #1c1c22 6px, #202028 6px, #202028 12px); }
  .pop-ava img { width: 100%; height: 100%; object-fit: cover; }
  .pop-name { font: 800 15px var(--display); color: #fff; }
  .pop-class { position: absolute; top: 9px; right: 11px; font-size: 22px; line-height: 1; }
  .pop-el { font: 400 9.5px var(--mono); color: var(--lime); margin-top: 2px; }
  .pop-desc { font: 400 11px/1.55 var(--mono); color: var(--tx-body); }

  @media (max-width: 900px) {
    .tl-layout { grid-template-columns: 1fr; }
    .tier-badge { width: 68px; }
    .tb-label { font-size: 22px; }
    .tl-popup { position: fixed; left: 50% !important; top: 50% !important; transform: translate(-50%, -50%); width: min(300px, 90vw); }
  }
</style>

<script>
  const popup = document.getElementById('tl-popup');
  const el = (id) => document.getElementById(id);
  let hideTimer;
  function show(a) {
    el('pop-name').textContent = a.dataset.name || '';
    const cls = a.dataset.class || '';
    el('pop-class').textContent = cls;
    el('pop-class').style.display = cls ? '' : 'none';
    const elm = a.dataset.el || '';
    el('pop-el').textContent = elm ? elm.toUpperCase() : '';
    el('pop-el').style.display = elm ? '' : 'none';
    el('pop-ava').innerHTML = a.dataset.img ? `<img src="${a.dataset.img}" alt="">` : '';
    const d = a.dataset.desc || '';
    el('pop-desc').textContent = d;
    el('pop-desc').style.display = d ? '' : 'none';
    popup.hidden = false;
    if (window.matchMedia('(min-width: 901px)').matches) {
      const r = a.getBoundingClientRect();
      let left = r.right + window.scrollX + 12;
      if (left + 260 > window.scrollX + document.documentElement.clientWidth - 8) left = r.left + window.scrollX - 260 - 12;
      popup.style.left = `${left}px`;
      popup.style.top = `${r.top + window.scrollY - 6}px`;
    }
  }
  const hide = () => { popup.hidden = true; };
  popup.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  popup.addEventListener('mouseleave', hide);
  window.addEventListener('scroll', hide, { passive: true });
  document.addEventListener('click', (e) => { if (!popup.contains(e.target) && !e.target.closest('.avatar')) hide(); });
  document.querySelectorAll('.avatar').forEach((a) => {
    const open = () => { clearTimeout(hideTimer); document.querySelectorAll('.avatar.on').forEach((x) => x.classList.remove('on')); a.classList.add('on'); show(a); };
    a.addEventListener('mouseenter', () => { hideTimer = window.setTimeout(open, 100); });
    a.addEventListener('mouseleave', () => { clearTimeout(hideTimer); hideTimer = window.setTimeout(hide, 150); });
    a.addEventListener('click', open);
    a.addEventListener('keydown', (e) => { if (e.key === 'Enter') open(); });
  });
</script>
