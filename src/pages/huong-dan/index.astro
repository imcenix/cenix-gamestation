---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Thumb from '../../components/Thumb.astro';
import { GUIDE_LEVELS, GUIDE_FILTERS, GUIDE_LABEL } from '../../lib/labels';
import { dm, byOrderThenDate } from '../../lib/format';

const guides = (await getCollection('guides')).sort(byOrderThenDate);
const countByLevel = (key) => guides.filter((g) => g.data.level === key).length;
const cover = (slug, file) => (file ? `/guides/${slug}/${file}` : null);
---

<BaseLayout title="Hướng dẫn" activeNav="guide" description="Hướng dẫn game từ tân thủ đến endgame: reroll, build nhân vật, farm tài nguyên.">
  <div class="page-head">
    <div class="crumb">TRANG CHỦ / <span class="here">HƯỚNG DẪN</span></div>
    <div class="page-head-row">
      <div class="page-title">HƯỚNG DẪN</div>
      <div class="page-meta">TỪ TÂN THỦ ĐẾN ENDGAME · {guides.length} BÀI</div>
    </div>
  </div>

  <section class="gut roadmap-wrap">
    <div class="sec-head">
      <div class="eyebrow">◆ LỘ TRÌNH ĐỀ XUẤT</div>
      <div class="rule"></div>
    </div>
    <div class="roadmap">
      {GUIDE_LEVELS.map((lvl, i) => (
        <a class="rm-cell" href={`#guide-${lvl.key}`} data-jump={lvl.key}>
          <div class:list={['rm-no', { first: i === 0 }]}>{lvl.no}</div>
          <div class="rm-title">{lvl.title}</div>
          <div class="rm-desc">{lvl.desc}</div>
          <div class="rm-count">{countByLevel(lvl.key)} BÀI →</div>
        </a>
      ))}
    </div>
  </section>

  <section class="gut guide-list">
    <div class="gl-head">
      <div class="sec-title" style="font-size:22px">GUIDE MỚI NHẤT</div>
      <div class="gl-filters">
        <button class="chip small active" data-filter="all">TẤT CẢ</button>
        {GUIDE_FILTERS.map((l) => <button class="chip small" data-filter={l.key}>{l.label}</button>)}
      </div>
    </div>

    <div class="g-grid" id="guide-grid">
      {guides.map((g) => (
        <a class="g-card" href={`/huong-dan/${g.data.slug}`} data-level={g.data.level}>
          <Thumb src={cover(g.id, g.data.cover)} label="thumb guide" class="g-thumb" />
          <div class="g-body">
            <div class="g-meta">
              <span class="kicker">{GUIDE_LABEL[g.data.level]}</span>
              <span class="dot">·</span>
              <span class="g-date">CẬP NHẬT {dm(g.data.date)}</span>
            </div>
            <div class="g-title">{g.data.title}</div>
            {g.data.tags.length > 0 && (
              <div class="g-tags">
                {g.data.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
      <p class="empty" id="g-empty" hidden>Chưa có guide trong cấp độ này.</p>
    </div>

    <div class="more"><button class="btn-outline" id="more-guides">XEM THÊM GUIDE ↓</button></div>
  </section>
</BaseLayout>

<style>
  .roadmap-wrap { padding-top: 36px; }
  .roadmap { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid var(--bd-card); border-radius: 3px; overflow: hidden; }
  .rm-cell { padding: 24px; border-right: 1px solid rgba(255, 255, 255, 0.1); display: flex; flex-direction: column; gap: 10px; color: #fff; min-height: 150px; }
  .rm-cell:last-child { border-right: none; }
  .rm-cell:first-child { background: linear-gradient(160deg, rgba(200, 240, 60, 0.08), transparent 60%); }
  .rm-no { font: 900 30px var(--display); color: rgba(255, 255, 255, 0.25); }
  .rm-no.first { color: var(--lime); }
  .rm-title { font: 800 16px var(--display); }
  .rm-desc { font: 400 10.5px/1.55 var(--mono); color: var(--tx-dim); }
  .rm-count { font: 700 10px var(--mono); color: var(--lime); margin-top: auto; }
  .rm-cell:hover .rm-title { color: var(--lime); }

  .guide-list { padding-top: 44px; padding-bottom: 48px; }
  .gl-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
  .gl-filters { display: flex; gap: 8px; margin-left: auto; flex-wrap: wrap; }
  .chip.small { font-size: 10px; padding: 6px 14px; border-radius: 16px; }

  .g-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .g-card { border: 1px solid var(--bd-card); border-radius: 3px; overflow: hidden; background: var(--surface); color: #fff; display: flex; flex-direction: column; }
  .g-card :global(.g-thumb) { width: 100%; height: 140px; }
  .g-body { padding: 18px; display: flex; flex-direction: column; gap: 9px; }
  .g-meta { display: flex; gap: 8px; align-items: center; }
  .g-meta .dot { color: var(--tx-faint); font: 400 9px var(--mono); }
  .g-date { font: 400 9px var(--mono); color: var(--tx-dim); }
  .g-title { font: 800 16px/1.3 var(--display); }
  .g-card:hover .g-title { color: var(--lime); }
  .g-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 2px; }
  .tag { background: rgba(255, 255, 255, 0.07); font: 400 9px var(--mono); padding: 3px 8px; border-radius: 2px; color: var(--tx-55); }
  .empty { grid-column: 1 / -1; padding: 30px 0; text-align: center; font: 400 12px var(--mono); color: var(--tx-meta); }

  .more { display: flex; justify-content: center; margin-top: 34px; }

  @media (max-width: 900px) {
    .roadmap { grid-template-columns: repeat(2, 1fr); }
    .rm-cell:nth-child(2) { border-right: none; }
    .rm-cell:nth-child(1), .rm-cell:nth-child(2) { border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
    .g-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .roadmap { grid-template-columns: 1fr; }
    .rm-cell { border-right: none; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
    .g-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const chips = document.querySelectorAll('.gl-filters .chip');
  const cards = document.querySelectorAll('#guide-grid .g-card');
  const empty = document.getElementById('g-empty');

  function apply(f) {
    chips.forEach((c) => c.classList.toggle('active', c.dataset.filter === f));
    let shown = 0;
    cards.forEach((el) => {
      const match = f === 'all' || el.dataset.level === f;
      el.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    if (empty) empty.hidden = shown > 0;
  }

  chips.forEach((chip) => chip.addEventListener('click', () => apply(chip.dataset.filter)));

  document.querySelectorAll('[data-jump]').forEach((cell) => {
    cell.addEventListener('click', (e) => {
      e.preventDefault();
      apply(cell.dataset.jump);
      document.querySelector('.guide-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
