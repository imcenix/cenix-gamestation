---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Thumb from '../../components/Thumb.astro';
import { GUIDE_LABEL } from '../../lib/labels';
import { dmy, readMinutes } from '../../lib/format';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const mins = readMinutes(entry.body);
const cover = d.cover ? `/guides/${entry.id}/${d.cover}` : null;
---

<BaseLayout title={d.title} activeNav="guide" description={d.excerpt ?? undefined}>
  <article class="article gut">
    <div class="crumb">TRANG CHỦ / <a href="/huong-dan">HƯỚNG DẪN</a> / <span class="here">{GUIDE_LABEL[d.level]}</span></div>

    <div class="kicker art-kicker">{GUIDE_LABEL[d.level]}</div>
    <h1 class="art-title">{d.title}</h1>
    <div class="art-meta">
      <span>CẬP NHẬT {dmy(d.date)}</span>
      <span class="dot">·</span>
      <span>{mins} PHÚT ĐỌC</span>
    </div>
    {d.tags.length > 0 && (
      <div class="art-tags">{d.tags.map((t) => <span class="tag">{t}</span>)}</div>
    )}

    {d.excerpt && <p class="art-lede">{d.excerpt}</p>}

    <div class="art-cover"><Thumb src={cover} label="thumb guide" class="cover-img" /></div>

    <div class="prose"><Content /></div>

    <a class="back" href="/huong-dan">← Tất cả hướng dẫn</a>
  </article>
</BaseLayout>

<style>
  .article { padding-top: 40px; padding-bottom: 56px; max-width: 860px; margin: 0 auto; }
  .art-kicker { letter-spacing: 1.5px; margin: 22px 0 12px; }
  .art-title { font: 900 40px/1.1 var(--display); letter-spacing: -1px; }
  .art-meta { display: flex; align-items: center; gap: 10px; margin-top: 16px; font: 400 10.5px var(--mono); color: var(--tx-55); }
  .art-meta .dot { color: var(--tx-faint); }
  .art-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 14px; }
  .tag { background: rgba(255, 255, 255, 0.07); font: 400 9px var(--mono); padding: 3px 8px; border-radius: 2px; color: var(--tx-55); }
  .art-lede { font: 400 17px/1.6 var(--display); color: var(--tx-body); margin: 24px 0 0; }
  .art-cover { margin: 28px 0 32px; }
  .art-cover :global(.cover-img) { width: 100%; height: 380px; border-radius: 3px; }
  .back { display: inline-block; margin-top: 40px; font: 700 11px var(--mono); color: var(--lime); }

  @media (max-width: 760px) {
    .art-title { font-size: 28px; }
    .art-cover :global(.cover-img) { height: 220px; }
  }
</style>
