---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Thumb from '../components/Thumb.astro';
import VideoThumb from '../components/VideoThumb.astro';
import Reviews from '../components/Reviews.astro';
import { SITE } from '../config/site';
import { NEWS_LABEL, GUIDE_LABEL } from '../lib/labels';
import { dmy, byOrderThenDate } from '../lib/format';
import { readFileSync } from 'node:fs';

const news = (await getCollection('news')).sort(byOrderThenDate);
const guides = (await getCollection('guides')).sort(byOrderThenDate);
let vorder: string[] = [];
try { vorder = JSON.parse(readFileSync('./assets/videos/_order_videos.json', 'utf-8')); } catch {}
const voi = (id: string) => { const i = vorder.indexOf(id); return i === -1 ? 9999 : i; };
const videos = (await getCollection('videos')).sort((a, b) => {
  const d = voi(a.id) - voi(b.id);
  return d !== 0 ? d : new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const tierlists = (await getCollection('tierlists')).sort(byOrderThenDate);
const allReviews = (await getCollection('reviews')).sort(byOrderThenDate);
const reviewCount = allReviews.length;
const reviews = allReviews.slice(0, 5).map((r) => ({ slug: r.id, title: r.data.title, cover: r.data.cover, score: r.data.score, review: r.data.review, platforms: r.data.platforms, genre: r.data.genre }));

const stats = { posts: news.length + guides.length, tiers: tierlists.length * 3, reviews: reviewCount };
const cover = (col: string, slug: string, file?: string | null) => (file ? `/${col}/${slug}/${file}` : null);

// News: 1 lead + 2 nhỏ (nổi bật); cột Tin tức = 5 kế tiếp
const leadNews = news.find((n) => n.data.featured) ?? news[0];
const restNews = news.filter((n) => n.id !== leadNews?.id);
const featSmall = restNews.slice(0, 2);
const newsCol = restNews.slice(2, 7);
const guidesCol = guides.slice(0, 5);

// Video: 1 lớn + 3 nhỏ (nổi bật); hàng 10 video
const featVideo = videos[0];
const featVideoSmall = videos.slice(1, 4);
const videoRow = videos.slice(4, 14);

// Tier-list: 3 bảng
function parseTiers(body: string) {
  try { const a = JSON.parse((body || '').trim() || '[]'); return Array.isArray(a) ? a : []; } catch { return []; }
}
const initials = (name: string) => name.split(/\s+/).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
const tier3 = tierlists.slice(0, 3).map((t) => {
  const tiers = parseTiers(t.body ?? '');
  return {
    slug: t.id, label: t.data.game_label,
    cover: t.data.cover ? `/tierlists/${t.id}/${t.data.cover}` : null,
    version: t.data.version, updated: t.data.updated ? dmy(t.data.updated) : '',
    rows: tiers.slice(0, 3).map((r: any) => ({
      label: r.label, color: r.color || '#888',
      chars: (r.chars || []).slice(0, 5).map((c: any) => ({ name: c.name, avatar: c.image ? `/tierlists/${t.id}/images/${c.image}` : null })),
    })),
  };
});
---

<BaseLayout title={SITE.name} activeNav="home" ticker>
  <section class="masthead">
    <div class="mh-bg">
      <video class="mh-video" autoplay muted loop playsinline preload="auto" src="/background-clip/01.mp4"></video>
      <div class="mh-tint"></div>
      <div class="mh-glow"></div>
    </div>
    <div class="mh-floats" aria-hidden="true">
      <span class="fl fl1"></span><span class="fl fl2"></span><span class="fl fl3"></span><span class="fl fl4"></span><span class="fl fl5"></span><span class="fl fl6"></span>
    </div>
    <div class="mh-content">
      <div class="est">{SITE.est}</div>
      <h1 class="wordmark"><span class="wm-line">CENIX</span><br /><span class="outline">GAME STATION</span></h1>
      <div class="stats">
        <span><b>{stats.posts}+</b>&nbsp; BÀI VIẾT</span>
        <span class="sep"><b>{stats.tiers}</b>&nbsp; TIER-LIST</span>
        <span class="sep"><b>{stats.reviews}</b>&nbsp; REVIEW</span>
      </div>
    </div>
  </section>

  <Reviews items={reviews} heading="REVIEW &quot;CÚ LẸ&quot;" subheading="TRONG TUẦN" note="CENIX CHẤM TẠM" moreHref="/review" scroll />

  {tier3.length > 0 && (
    <section class="gut block">
      <div class="sec-head"><div class="sec-title">TIER-LIST</div><div class="rule"></div><a class="sec-more" href="/tier-list">TẤT CẢ →</a></div>
      <div class="tl3-grid">
        {tier3.map((t) => (
          <a class="tl3-card" href={`/tier-list/${t.slug}`}>
            <div class="tl3-art"><Thumb src={t.cover} label={`key art — ${t.label}`} class="tl3-img" /><span class="tl3-badge-tag">TIER-LIST</span></div>
            <div class="tl3-body">
              <div class="tl3-top">
                <div class="tl3-name">{t.label}</div>
                <div class="tl3-meta">{t.version ? `BẢN ${t.version}` : ''}{t.updated ? ` · ${t.updated}` : ''}</div>
              </div>
              <div class="tl3-preview">
                {t.rows.map((r) => (
                  <div class="tl3-row">
                    <span class="tl3-badge" style={`background:${r.color}`}>{r.label}</span>
                    <div class="tl3-track">
                      {r.chars.length === 0 ? <span class="tl3-empty">—</span> : r.chars.map((c) => (
                        <span class="tl3-ava">{c.avatar ? <img src={c.avatar} alt={c.name} loading="lazy" /> : <span class="tl3-ab">{initials(c.name)}</span>}</span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <div class="tl3-cta">XEM CHI TIẾT →</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {leadNews && (
    <section class="gut block">
      <div class="sec-head"><div class="sec-title">TIN NỔI BẬT</div><div class="rule"></div></div>
      <div class="feat-news">
        <a class="fn-lead" href={`/tin-tuc/${leadNews.data.slug}`}>
          <Thumb src={cover('news', leadNews.id, leadNews.data.cover)} label="key art" class="fill" />
          <div class="fn-shade"></div>
          <div class="fn-lead-body">
            <div class="row-meta"><span class="badge">TIN NÓNG</span><span class="meta">{dmy(leadNews.data.date)} · {leadNews.data.read_minutes ?? 5} PHÚT ĐỌC</span></div>
            <h2 class="fn-lead-title">{leadNews.data.title}</h2>
            {leadNews.data.excerpt && <p class="fn-lead-dek clamp2">{leadNews.data.excerpt}</p>}
          </div>
        </a>
        <div class="fn-side">
          {featSmall.map((n) => (
            <a class="fn-small" href={`/tin-tuc/${n.data.slug}`}>
              <Thumb src={cover('news', n.id, n.data.cover)} label="thumb" class="fn-small-thumb" />
              <div class="fn-small-body">
                <div class="kicker">{NEWS_LABEL[n.data.category]}</div>
                <div class="fn-small-title clamp2">{n.data.title}</div>
                <div class="fn-small-meta">{dmy(n.data.date)}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="gut block two-col">
    <div class="tc-col">
      <div class="sec-head"><div class="sec-title" style="font-size:22px">TIN TỨC</div><a class="sec-more" href="/tin-tuc">TẤT CẢ →</a></div>
      <div class="li-list">
        {newsCol.map((n) => (
          <a class="li-row" href={`/tin-tuc/${n.data.slug}`}>
            <Thumb src={cover('news', n.id, n.data.cover)} label="thumb" class="li-thumb" />
            <div class="li-body">
              <div class="kicker">{NEWS_LABEL[n.data.category]}</div>
              <div class="li-title clamp2">{n.data.title}</div>
              {n.data.excerpt && <div class="li-dek clamp3">{n.data.excerpt}</div>}
            </div>
          </a>
        ))}
        {newsCol.length === 0 && <p class="li-empty">Chưa có thêm bài.</p>}
      </div>
    </div>
    <div class="tc-col">
      <div class="sec-head"><div class="sec-title" style="font-size:22px">HƯỚNG DẪN</div><a class="sec-more" href="/huong-dan">TẤT CẢ →</a></div>
      <div class="li-list">
        {guidesCol.map((g) => (
          <a class="li-row" href={`/huong-dan/${g.data.slug}`}>
            <Thumb src={cover('guides', g.id, g.data.cover)} label="thumb" class="li-thumb" />
            <div class="li-body">
              <div class="kicker">{GUIDE_LABEL[g.data.level]}</div>
              <div class="li-title clamp2">{g.data.title}</div>
              {g.data.tags.length > 0 && <div class="li-tags">{g.data.tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}</div>}
            </div>
          </a>
        ))}
        {guidesCol.length === 0 && <p class="li-empty">Chưa có bài hướng dẫn.</p>}
      </div>
    </div>
  </section>

  {featVideo && (
    <section class="gut block last">
      <div class="sec-head"><div class="sec-title">VIDEO</div><div class="rule"></div><a class="sec-more" href={SITE.socials.youtube} target="_blank" rel="noopener">KÊNH YOUTUBE →</a></div>
      <div class="feat-vid">
        <a class="fv-lead" href="/video">
          <VideoThumb url={featVideo.data.youtube_url} height={0} playSize={44} />
          <div class="fv-shade"></div>
          <div class="fv-body"><div class="fv-title">{featVideo.data.title}</div><div class="kicker">VIDEO · YOUTUBE</div></div>
        </a>
        <div class="fv-side">
          {featVideoSmall.map((v) => (
            <a class="fv-small" href="/video">
              <VideoThumb url={v.data.youtube_url} height={115} playSize={24} />
              <div class="fv-small-body">
                <div class="fv-small-title clamp3">{v.data.title}</div>
                <div class="fv-small-meta">VIDEO · YOUTUBE</div>
              </div>
            </a>
          ))}
        </div>
      </div>
      {videoRow.length > 0 && (
        <div class="vrow">
          {videoRow.map((v) => (
            <a class="vrow-item" href="/video">
              <VideoThumb url={v.data.youtube_url} height={104} playSize={28} />
              <div class="vrow-title clamp2">{v.data.title}</div>
            </a>
          ))}
        </div>
      )}
    </section>
  )}
</BaseLayout>

<style>
  .block { padding-top: 46px; }
  .last { padding-bottom: 56px; }
  .clamp2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .clamp3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .badge { background: var(--lime); color: var(--on-lime); font: 700 10px var(--mono); padding: 3px 9px; border-radius: 2px; }
  .meta { font: 400 10px var(--mono); color: var(--tx-dim); }
  .row-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

  /* Masthead */
  .masthead { position: relative; overflow: hidden; min-height: 660px; margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 60px 20px; border-bottom: 1px solid var(--bd-divider); }
  .mh-bg { position: absolute; inset: 0; z-index: 0; background: #0a0a0b; }
  .mh-video { width: 100%; height: 100%; object-fit: cover; opacity: 0.55; filter: saturate(0.3) brightness(0.6) contrast(1.05); }
  .mh-tint { position: absolute; inset: 0; background: radial-gradient(ellipse 62% 55% at 50% 42%, rgba(120, 200, 40, 0.20), transparent 62%), linear-gradient(180deg, rgba(10, 10, 11, 0.5) 0%, rgba(10, 10, 11, 0.28) 45%, rgba(10, 10, 11, 0.94) 100%); }
  .mh-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 55% 70% at 50% 100%, rgba(200, 240, 60, 0.14), transparent 65%); pointer-events: none; }
  .mh-floats { position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
  .fl { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(200, 240, 60, 0.6), rgba(200, 240, 60, 0) 70%); filter: blur(0.5px); animation: floaty ease-in-out infinite; }
  .fl1 { width: 10px; height: 10px; left: 12%; top: 30%; animation-duration: 9s; }
  .fl2 { width: 6px; height: 6px; left: 80%; top: 22%; animation-duration: 12s; animation-delay: -3s; }
  .fl3 { width: 14px; height: 14px; left: 86%; top: 62%; animation-duration: 11s; animation-delay: -5s; }
  .fl4 { width: 5px; height: 5px; left: 22%; top: 68%; animation-duration: 14s; animation-delay: -2s; }
  .fl5 { width: 8px; height: 8px; left: 50%; top: 16%; animation-duration: 10s; animation-delay: -6s; }
  .fl6 { width: 7px; height: 7px; left: 66%; top: 78%; animation-duration: 13s; animation-delay: -1s; }
  @keyframes floaty { 0%, 100% { transform: translateY(0) translateX(0); opacity: 0.15; } 50% { transform: translateY(-28px) translateX(12px); opacity: 0.85; } }
  .mh-content { position: relative; z-index: 2; }
  .est { position: relative; font: 400 11px var(--mono); color: var(--lime); letter-spacing: 4px; margin-bottom: 16px; text-shadow: 0 0 12px rgba(200, 240, 60, 0.5); }
  .wordmark { position: relative; font: 900 112px/0.9 var(--display); letter-spacing: -3px; }
  .wm-line { color: #fff; text-shadow: 0 0 26px rgba(255, 255, 255, 0.25), 0 0 70px rgba(200, 240, 60, 0.25); }
  .outline { -webkit-text-stroke: 2px var(--lime); color: transparent; filter: drop-shadow(0 0 16px rgba(200, 240, 60, 0.55)); animation: wmglow 3.6s ease-in-out infinite; }
  @keyframes wmglow { 0%, 100% { filter: drop-shadow(0 0 10px rgba(200, 240, 60, 0.4)); } 50% { filter: drop-shadow(0 0 30px rgba(200, 240, 60, 0.85)); } }
  .stats { position: relative; display: flex; justify-content: center; gap: 36px; margin-top: 34px; font: 400 10.5px var(--mono); color: var(--tx-55); }
  .stats b { color: #fff; font: 900 15px var(--display); }
  .stats .sep { border-left: 1px solid rgba(255, 255, 255, 0.2); padding-left: 36px; }

  /* Tier-list 3 boards */
  .tl3-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .tl3-card { border: 1px solid var(--bd-card); border-radius: 4px; overflow: hidden; background: var(--surface); color: #fff; display: flex; flex-direction: column; }
  .tl3-card:hover { border-color: var(--lime-40); }
  .tl3-art { position: relative; aspect-ratio: 16 / 8; }
  .tl3-art :global(.tl3-img) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tl3-badge-tag { position: absolute; top: 10px; left: 10px; background: var(--lime); color: var(--on-lime); font: 700 9px var(--mono); letter-spacing: 1px; padding: 3px 8px; border-radius: 2px; }
  .tl3-body { padding: 16px 16px 14px; display: flex; flex-direction: column; gap: 12px; }
  .tl3-top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .tl3-name { font: 900 18px var(--display); }
  .tl3-card:hover .tl3-name { color: var(--lime); }
  .tl3-meta { font: 400 9px var(--mono); color: var(--tx-meta); white-space: nowrap; }
  .tl3-preview { display: flex; flex-direction: column; gap: 5px; }
  .tl3-row { display: flex; gap: 6px; align-items: stretch; }
  .tl3-badge { width: 30px; flex: none; color: var(--on-lime); font: 900 12px var(--display); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .tl3-track { flex: 1; background: var(--surface-2); border: 1px solid var(--bd-soft); border-radius: 2px; padding: 4px 6px; display: flex; gap: 4px; flex-wrap: wrap; align-items: center; min-height: 34px; }
  .tl3-ava { width: 26px; height: 26px; flex: none; border-radius: 2px; overflow: hidden; background: linear-gradient(145deg, #f3ddf0 0%, #dde6fb 55%, #dbf1e7 100%); display: flex; align-items: center; justify-content: center; }
  .tl3-ava img { width: 100%; height: 100%; object-fit: cover; }
  .tl3-ab { font: 700 7px var(--mono); color: rgba(24, 24, 34, 0.5); }
  .tl3-empty { font: 400 9px var(--mono); color: var(--tx-faint); }
  .tl3-cta { font: 700 10px var(--mono); color: var(--lime); margin-top: auto; }

  /* Featured news */
  .feat-news { display: grid; grid-template-columns: 1.5fr 1fr; gap: 16px; }
  .fn-lead { position: relative; border-radius: 4px; overflow: hidden; min-height: 360px; color: #fff; }
  .fn-lead :global(.fill) { position: absolute; inset: 0; width: 100%; height: 100%; }
  .fn-shade { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(10, 10, 11, 0.96) 0%, rgba(10, 10, 11, 0.4) 45%, transparent 72%); }
  .fn-lead-body { position: absolute; left: 26px; right: 26px; bottom: 24px; display: flex; flex-direction: column; gap: 10px; }
  .fn-lead-title { font: 900 30px/1.1 var(--display); letter-spacing: -0.5px; }
  .fn-lead:hover .fn-lead-title { color: var(--lime); }
  .fn-lead-dek { font: 400 12.5px/1.55 var(--display); color: var(--tx-65); max-width: 520px; margin: 0; }
  .fn-side { display: flex; flex-direction: column; gap: 14px; }
  .fn-small { display: flex; gap: 12px; color: #fff; border: 1px solid var(--bd-card); border-radius: 3px; overflow: hidden; background: var(--surface); flex: 1; }
  .fn-small :global(.fn-small-thumb) { width: 116px; flex: none; object-fit: cover; }
  .fn-small-body { padding: 12px 12px 12px 0; display: flex; flex-direction: column; gap: 6px; justify-content: center; }
  .fn-small-title { font: 800 14px/1.3 var(--display); }
  .fn-small:hover .fn-small-title { color: var(--lime); }
  .fn-small-meta { font: 400 9px var(--mono); color: var(--tx-faint); }

  /* 2-col Tin tức / Hướng dẫn */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .tc-col .sec-head { margin-bottom: 6px; }
  .li-list { display: flex; flex-direction: column; }
  .li-row { display: flex; gap: 16px; padding: 18px 0; border-bottom: 1px solid var(--bd-divider); color: #fff; }
  .li-row:last-child { border-bottom: none; }
  .li-row :global(.li-thumb) { width: 130px; height: 82px; border-radius: 3px; flex: none; object-fit: cover; }
  .li-body { display: flex; flex-direction: column; gap: 7px; justify-content: center; min-width: 0; }
  .li-title { font: 800 15px/1.3 var(--display); }
  .li-row:hover .li-title { color: var(--lime); }
  .li-dek { font: 400 11.5px/1.5 var(--display); color: var(--tx-dim); }
  .li-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag { background: rgba(255, 255, 255, 0.07); font: 400 9px var(--mono); padding: 3px 8px; border-radius: 2px; color: var(--tx-55); }
  .li-empty { font: 400 11px var(--mono); color: var(--tx-meta); padding: 16px 0; }

  /* Featured video */
  .feat-vid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 16px; }
  .fv-lead { position: relative; aspect-ratio: 16 / 9; border-radius: 4px; overflow: hidden; color: #fff; }
  .fv-lead :global(.vthumb) { position: absolute; inset: 0; height: 100% !important; }
  .fv-shade { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(10, 10, 11, 0.9), transparent 55%); pointer-events: none; }
  .fv-body { position: absolute; left: 18px; right: 18px; bottom: 16px; display: flex; flex-direction: column; gap: 5px; }
  .fv-title { font: 800 17px/1.3 var(--display); }
  .fv-side { display: flex; flex-direction: column; gap: 0; justify-content: space-between; }
  .fv-small { display: flex; gap: 14px; color: #fff; align-items: flex-start; }
  .fv-small :global(.vthumb) { width: 205px; flex: none; }
  .fv-small-body { display: flex; flex-direction: column; gap: 6px; padding-top: 1px; min-width: 0; }
  .fv-small-title { font: 800 14px/1.35 var(--display); }
  .fv-small:hover .fv-small-title { color: var(--lime); }
  .fv-small-meta { font: 400 9px var(--mono); color: var(--tx-faint); letter-spacing: 0.5px; }

  /* Video row (10, scroll ngang) */
  .vrow { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 24px; }
  .vrow-item { color: #fff; display: flex; flex-direction: column; gap: 8px; }
  .vrow-title { font: 700 12px/1.3 var(--display); }
  .vrow-item:hover .vrow-title { color: var(--lime); }

  @media (max-width: 1100px) { .wordmark { font-size: 84px; } .masthead { min-height: 560px; } .vrow { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 900px) {
    .wordmark { font-size: 64px; letter-spacing: -2px; }
    .est { display: none; }
    .masthead { min-height: 480px; padding: 78px 16px 48px; justify-content: center; }
    .stats { gap: 20px; flex-wrap: wrap; }
    .stats .sep { padding-left: 20px; }
    .tl3-grid { grid-template-columns: 1fr; }
    .feat-news, .feat-vid { grid-template-columns: 1fr; }
    .fn-lead { min-height: 300px; }
    .two-col { grid-template-columns: 1fr; gap: 40px; }
    /* Video row → 1 hàng scroll ngang */
    .vrow { display: flex; overflow-x: auto; gap: 12px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 6px; }
    .vrow-item { width: 220px; flex: none; scroll-snap-align: start; }
  }
  @media (max-width: 560px) {
    .masthead { min-height: 430px; padding: 74px 14px 42px; }
    .wordmark { font-size: 46px; letter-spacing: -1px; }
    .est { letter-spacing: 2px; margin-bottom: 10px; }
    .stats { gap: 14px; margin-top: 22px; }
    .stats .sep { padding-left: 14px; }
    .fn-side { gap: 10px; }
    .fn-small :global(.fn-small-thumb) { width: 100px; }
    .fv-small :global(.vthumb) { width: 150px; }
    .li-row :global(.li-thumb) { width: 108px; height: 70px; }
  }
</style>
