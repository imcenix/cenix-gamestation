---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../layouts/BaseLayout.astro';
import Thumb from '../components/Thumb.astro';
import VideoThumb from '../components/VideoThumb.astro';
import Reviews from '../components/Reviews.astro';
import { SITE } from '../config/site';
import { NEWS_LABEL, GUIDE_LABEL } from '../lib/labels';
import { dmy, byOrderThenDate } from '../lib/format';
import { readFileSync } from 'node:fs';

const news = (await getCollection('news')).sort(byOrderThenDate);
const guides = (await getCollection('guides')).sort(byOrderThenDate);
let vorder: string[] = [];
try { vorder = JSON.parse(readFileSync('./assets/videos/_order_videos.json', 'utf-8')); } catch {}
const voi = (id: string) => { const i = vorder.indexOf(id); return i === -1 ? 9999 : i; };
const videos = (await getCollection('videos')).sort((a, b) => {
  const d = voi(a.id) - voi(b.id);
  return d !== 0 ? d : new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const tierlists = (await getCollection('tierlists')).sort(byOrderThenDate);
const allReviews = (await getCollection('reviews')).sort(byOrderThenDate);
const reviewCount = allReviews.length;
const reviewHtml = (r: any) => marked.parse(((r.body && r.body.trim()) ? r.body : (r.data.review || '')).trim()) as string;
const reviews = allReviews.slice(0, 5).map((r) => ({ slug: r.id, title: r.data.title, cover: r.data.cover, score: r.data.score, reviewHtml: reviewHtml(r), platforms: r.data.platforms, genre: Array.isArray(r.data.genre) ? r.data.genre : (r.data.genre ? [r.data.genre] : []) }));

const stats = { posts: news.length + guides.length, tiers: tierlists.length * 3, reviews: reviewCount };
const cover = (col: string, slug: string, file?: string | null) => (file ? `/${col}/${slug}/${file}` : null);

const selectedGames = [
  { title: 'Clair Obscur: Expedition 33', kicker: 'RPG · A PERSONAL FAVORITE', note: 'Một chuyến đi đẹp, buồn và đủ khác biệt để còn ở lại rất lâu sau đoạn credit.', image: '/images/showcase/games/clair-obscur-expedition-33.webp', href: '/review' },
  { title: 'Crimson Desert', kicker: 'OPEN WORLD · ACTION', note: 'Thế giới lớn, va chạm mạnh và cảm giác phiêu lưu luôn ở phía trước.', image: '/images/showcase/games/crimson-desert.webp', href: '/review' },
  { title: "Marvel’s Wolverine", kicker: 'PS5 · ACTION', note: 'Dữ dội, bản năng và đúng kiểu nhân vật không cần phải nói quá nhiều.', image: '/images/showcase/games/marvels-wolverine.webp', href: '/video' },
  { title: 'Elden Ring', kicker: 'SOULS · RPG', note: 'Lạc đường, thất bại, học lại — rồi cuối cùng tự viết nên cuộc hành trình của mình.', image: '/images/showcase/games/elden-ring.webp', href: '/profile' },
  { title: 'Grand Theft Auto VI', kicker: 'ROCKSTAR · OPEN WORLD', note: 'Một thế giới hỗn loạn luôn biết cách khiến người chơi muốn nhìn thêm lần nữa.', image: '/images/showcase/games/gta-6.webp', href: '/tin-tuc/gta6-pc-chayduockhong' },
  { title: 'Solo Leveling', kicker: 'ACTION RPG · ANIME', note: 'Tăng cấp, săn boss và theo đuổi cảm giác mạnh lên sau từng trận chiến.', image: '/images/showcase/games/solo-leveling.webp', href: '/tin-tuc' },
  { title: 'Onimusha: Way of the Sword', kicker: 'SAMURAI · ACTION', note: 'Thép, máu và tinh thần samurai trong một thế giới không hề hiền lành.', image: '/images/showcase/games/onimusha-way-of-the-samurai.webp', href: '/tin-tuc' },
];

// News: 1 lead + 2 nhỏ (nổi bật); cột Tin tức = 5 kế tiếp
const leadNews = news.find((n) => n.data.featured) ?? news[0];
const restNews = news.filter((n) => n.id !== leadNews?.id);
const featSmall = restNews.slice(0, 2);
const newsCol = restNews.slice(2, 7);
const guidesCol = guides.slice(0, 5);

// Video: 1 lớn + 3 nhỏ (nổi bật); hàng 10 video
const featVideo = videos[0];
const featVideoSmall = videos.slice(1, 4);
const videoRow = videos.slice(4, 14);

// Tier-list: 3 bảng
function parseTiers(body: string) {
  try { const a = JSON.parse((body || '').trim() || '[]'); return Array.isArray(a) ? a : []; } catch { return []; }
}
const initials = (name: string) => name.split(/\s+/).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
const tier3 = tierlists.slice(0, 3).map((t) => {
  const tiers = parseTiers(t.body ?? '');
  return {
    slug: t.id, label: t.data.game_label,
    cover: t.data.cover ? `/tierlists/${t.id}/${t.data.cover}` : null,
    version: t.data.version, updated: t.data.updated ? dmy(t.data.updated) : '',
    rows: tiers.slice(0, 3).map((r: any) => ({
      label: r.label, color: r.color || '#888',
      chars: (r.chars || []).slice(0, 5).map((c: any) => ({ name: c.name, avatar: c.image ? `/tierlists/${t.id}/images/${c.image}` : null })),
    })),
  };
});
---

<BaseLayout title={SITE.name} activeNav="home" ticker>
  <section class="home-hero">
    <div class="hh-media" aria-hidden="true">
      <video class="hh-video" autoplay muted loop playsinline preload="metadata" poster="/images/showcase/hero-poster.webp" src="/images/showcase/hero.mp4"></video>
      <div class="hh-vignette"></div>
      <div class="hh-grid"></div>
      <div class="hh-noise"></div>
    </div>

    <div class="hh-copy">
      <h1 class="hh-title" aria-label="One Life Infinite Worlds">
        <span>ONE <em class="hh-outline-white">LIFE</em></span>
        <span class="hh-lime">INFINITE <em class="hh-outline-lime">WORLDS</em></span>
      </h1>
    </div>

    <div class="hh-footer">
      <div class="hh-stats">
        <span><b>{stats.posts}+</b> BÀI VIẾT</span>
        <span><b>{stats.tiers}</b> TIER-LIST</span>
        <span><b>{stats.reviews}</b> REVIEW</span>
      </div>
      <a class="hh-scroll" href="#manifesto"><span>SCROLL TO EXPLORE</span><i></i></a>
    </div>
  </section>

  <section class="story-sequence" id="manifesto">
    <div class="story-sticky">
      <div class="story-backgrounds" aria-hidden="true">
        <video class="story-bg story-bg-manifesto" autoplay muted loop playsinline preload="metadata" src="/images/showcase/backgrounds/manifesto.mp4"></video>
        <video class="story-bg story-bg-player" autoplay muted loop playsinline preload="metadata" src="/images/showcase/backgrounds/player-one.mp4"></video>
        <div class="story-bg-shade"></div>
      </div>
      <div class="story-grid" aria-hidden="true"></div>

      <div class="story-manifesto">
        <div class="manifesto-copy">
          <p class="manifesto-line manifesto-line-left">
            <span class="manifesto-lead">BE COUNTLESS</span>
            <span class="manifesto-outline manifesto-outline-white">HEROES</span>
          </p>
          <p class="manifesto-line manifesto-line-right">
            <span class="manifesto-lead">LIVE COUNTLESS</span>
            <span class="manifesto-outline manifesto-outline-lime">WORLDS</span>
          </p>
        </div>
      </div>

      <div class="story-characters" aria-hidden="true">
        <div class="story-char story-char-1"><img src="/images/showcase/characters/bowser.webp" alt="" /></div>
        <div class="story-char story-char-2"><img src="/images/showcase/characters/mario.webp" alt="" /></div>
        <div class="story-char story-char-3"><img src="/images/showcase/characters/donkey-kong.webp" alt="" /></div>
      </div>

      <div class="story-console" aria-hidden="true">
        <div class="story-screen">
          <div class="story-screen-grid"></div>
          <span class="story-screen-status">CENIX // PLAYER ONE</span>
          <strong>ENTER<br />THE WORLD</strong>
        </div>
        <div class="story-controller"><i></i><b></b><em></em><span></span></div>
      </div>

      <div class="story-player">
        <div class="story-player-copy">
          <div class="story-player-label">PLAYER ONE</div>
          <h2>CENIX</h2>
          <a class="story-profile-link" href="/profile">CENIX PROFILE <span>→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="selected-worlds" id="selected-worlds">
    <div class="sw-head gut">
      <h2 aria-label="Where Every World Awaits">
        <span>WHERE <em class="sw-outline-white">EVERY</em></span>
        <span><em class="sw-outline-lime">WORLD</em> <strong>AWAITS</strong></span>
      </h2>
    </div>

    <div class="game-mosaic gut">
      {selectedGames.map((game, index) => (
        <a class={`game-panel game-panel-${index + 1}`} href={game.href} aria-label={game.title}>
          <img src={game.image} alt={game.title} loading={index < 3 ? 'eager' : 'lazy'} />
          <div class="gp-shade"></div>
        </a>
      ))}
    </div>
  </section>

  <section class="adventure-line">
    <h2 aria-label="Where Every Adventure Begin">
      <span class="adventure-where">WHERE</span>
      <span class="adventure-outline">EVERY ADVENTURE</span>
      <span class="adventure-fill">BEGIN</span>
    </h2>
  </section>

  <Reviews items={reviews} heading="REVIEW &quot;CÚ LẸ&quot;" note="CENIX CHẤM TẠM" moreHref="/review" scroll />

  {tier3.length > 0 && (
    <section class="gut block">
      <div class="sec-head"><div class="sec-title">TIER-LIST</div><div class="rule"></div><a class="sec-more" href="/tier-list">TẤT CẢ →</a></div>
      <div class="tl3-grid">
        {tier3.map((t) => (
          <a class="tl3-card" href={`/tier-list/${t.slug}`}>
            <div class="tl3-art"><Thumb src={t.cover} label={`key art — ${t.label}`} class="tl3-img" /><span class="tl3-badge-tag">TIER-LIST</span></div>
            <div class="tl3-body">
              <div class="tl3-top">
                <div class="tl3-name">{t.label}</div>
                <div class="tl3-meta">{t.version ? `BẢN ${t.version}` : ''}{t.updated ? ` · ${t.updated}` : ''}</div>
              </div>
              <div class="tl3-preview">
                {t.rows.map((r) => (
                  <div class="tl3-row">
                    <span class="tl3-badge" style={`background:${r.color}`}>{r.label}</span>
                    <div class="tl3-track">
                      {r.chars.length === 0 ? <span class="tl3-empty">—</span> : r.chars.map((c) => (
                        <span class="tl3-ava">{c.avatar ? <img src={c.avatar} alt={c.name} loading="lazy" /> : <span class="tl3-ab">{initials(c.name)}</span>}</span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <div class="tl3-cta">XEM CHI TIẾT →</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="life-banner" aria-label="Don't Just Play. Live It">
    <div class="life-banner-art" aria-hidden="true"></div>
    <h2 aria-label="Don't Just Play. Live It">
      <span class="life-phrase"><strong>DON'T</strong> <em class="life-outline-white">JUST</em> <strong>PLAY.</strong></span>
      <span class="life-phrase"><strong class="life-lime">LIVE</strong> <em class="life-outline-lime">IT</em></span>
    </h2>
  </section>
  {leadNews && (
    <section class="gut block">
      <div class="sec-head"><div class="sec-title">TIN NỔI BẬT</div><div class="rule"></div></div>
      <div class="feat-news">
        <a class="fn-lead" href={`/tin-tuc/${leadNews.data.slug}`}>
          <Thumb src={cover('news', leadNews.id, leadNews.data.cover)} label="key art" class="fill" />
          <div class="fn-shade"></div>
          <div class="fn-lead-body">
            <div class="row-meta"><span class="badge">TIN NÓNG</span><span class="meta">{dmy(leadNews.data.date)} · {leadNews.data.read_minutes ?? 5} PHÚT ĐỌC</span></div>
            <h2 class="fn-lead-title">{leadNews.data.title}</h2>
            {leadNews.data.excerpt && <p class="fn-lead-dek clamp2">{leadNews.data.excerpt}</p>}
          </div>
        </a>
        <div class="fn-side">
          {featSmall.map((n) => (
            <a class="fn-small" href={`/tin-tuc/${n.data.slug}`}>
              <Thumb src={cover('news', n.id, n.data.cover)} label="thumb" class="fn-small-thumb" />
              <div class="fn-small-body">
                <div class="kicker">{NEWS_LABEL[n.data.category]}</div>
                <div class="fn-small-title clamp2">{n.data.title}</div>
                <div class="fn-small-meta">{dmy(n.data.date)}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="gut block two-col">
    <div class="tc-col">
      <div class="sec-head"><div class="sec-title" style="font-size:22px">TIN TỨC</div><a class="sec-more" href="/tin-tuc">TẤT CẢ →</a></div>
      <div class="li-list">
        {newsCol.map((n) => (
          <a class="li-row" href={`/tin-tuc/${n.data.slug}`}>
            <Thumb src={cover('news', n.id, n.data.cover)} label="thumb" class="li-thumb" />
            <div class="li-body">
              <div class="kicker">{NEWS_LABEL[n.data.category]}</div>
              <div class="li-title clamp2">{n.data.title}</div>
              {n.data.excerpt && <div class="li-dek clamp3">{n.data.excerpt}</div>}
            </div>
          </a>
        ))}
        {newsCol.length === 0 && <p class="li-empty">Chưa có thêm bài.</p>}
      </div>
    </div>
    <div class="tc-col">
      <div class="sec-head"><div class="sec-title" style="font-size:22px">HƯỚNG DẪN</div><a class="sec-more" href="/huong-dan">TẤT CẢ →</a></div>
      <div class="li-list">
        {guidesCol.map((g) => (
          <a class="li-row" href={`/huong-dan/${g.data.slug}`}>
            <Thumb src={cover('guides', g.id, g.data.cover)} label="thumb" class="li-thumb" />
            <div class="li-body">
              <div class="kicker">{GUIDE_LABEL[g.data.level]}</div>
              <div class="li-title clamp2">{g.data.title}</div>
              {g.data.tags.length > 0 && <div class="li-tags">{g.data.tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}</div>}
            </div>
          </a>
        ))}
        {guidesCol.length === 0 && <p class="li-empty">Chưa có bài hướng dẫn.</p>}
      </div>
    </div>
  </section>

  {featVideo && (
    <section class="gut block last">
      <div class="sec-head"><div class="sec-title">VIDEO</div><div class="rule"></div><a class="sec-more" href={SITE.socials.youtube} target="_blank" rel="noopener">KÊNH YOUTUBE →</a></div>
      <div class="feat-vid">
        <a class="fv-lead" href="/video">
          <VideoThumb url={featVideo.data.youtube_url} height={0} playSize={44} />
          <div class="fv-shade"></div>
          <div class="fv-body"><div class="fv-title">{featVideo.data.title}</div><div class="kicker">VIDEO · YOUTUBE</div></div>
        </a>
        <div class="fv-side">
          {featVideoSmall.map((v) => (
            <a class="fv-small" href="/video">
              <VideoThumb url={v.data.youtube_url} height={115} playSize={24} />
              <div class="fv-small-body">
                <div class="fv-small-title clamp3">{v.data.title}</div>
                <div class="fv-small-meta">VIDEO · YOUTUBE</div>
              </div>
            </a>
          ))}
        </div>
      </div>
      {videoRow.length > 0 && (
        <div class="vrow">
          {videoRow.map((v) => (
            <a class="vrow-item" href="/video">
              <VideoThumb url={v.data.youtube_url} height={104} playSize={28} />
              <div class="vrow-title clamp2">{v.data.title}</div>
            </a>
          ))}
        </div>
      )}
    </section>
  )}
</BaseLayout>

<script is:inline>
  (() => {
    const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
    const lerp = (start, end, amount) => start + ((end - start) * amount);
    const smooth = (start, end, value) => {
      const t = clamp((value - start) / (end - start));
      return t * t * (3 - 2 * t);
    };
    const story = document.querySelector('.story-sequence');
    const sticky = story?.querySelector('.story-sticky');
    const storyConsole = story?.querySelector('.story-console');
    const desktop = window.matchMedia('(min-width: 901px)');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');
    let ticking = false;

    const setVar = (name, value) => sticky?.style.setProperty(name, value);
    const renderStory = () => {
      ticking = false;
      if (!story || !sticky || !desktop.matches || reduced.matches) return;

      const rect = story.getBoundingClientRect();
      const distance = Math.max(1, story.offsetHeight - window.innerHeight);
      const progress = clamp(-rect.top / distance);
      const enter = smooth(.02, .32, progress);
      const leave = smooth(.38, .6, progress);
      const characterEnter = smooth(.03, .36, progress);
      const characterSettle = smooth(.38, .68, progress);
      const playerEnter = smooth(.5, .74, progress);
      const screenEnter = smooth(.46, .72, progress);
      const char1ManifestX = lerp(-30, 17, characterEnter);
      const char2ManifestY = lerp(-38, 9, characterEnter);
      const char3ManifestX = lerp(110, 69, characterEnter);
      const screenLeftVw = storyConsole ? (storyConsole.offsetLeft / window.innerWidth) * 100 : 49;
      const screenWidthVw = storyConsole ? (storyConsole.offsetWidth / window.innerWidth) * 100 : 42;
      const screenTopVh = storyConsole ? ((storyConsole.offsetTop - (storyConsole.offsetHeight * .44)) / window.innerHeight) * 100 : 25;
      const screenHeightVh = storyConsole ? ((storyConsole.offsetHeight - 54) / window.innerHeight) * 100 : 50;
      const char1ScreenX = screenLeftVw + (screenWidthVw * .04);
      const char2ScreenX = screenLeftVw + (screenWidthVw * .36);
      const char3ScreenX = screenLeftVw + (screenWidthVw * .66);
      const char1ScreenY = screenTopVh + (screenHeightVh * .28);
      const char2ScreenY = screenTopVh + (screenHeightVh * .07);
      const char3ScreenY = screenTopVh + (screenHeightVh * .28);

      setVar('--manifest-left-x', `${(-82 * (1 - enter)) + (44 * leave)}vw`);
      setVar('--manifest-right-x', `${(82 * (1 - enter)) - (44 * leave)}vw`);
      setVar('--manifest-opacity', String(enter * (1 - leave)));
      setVar('--player-opacity', String(playerEnter));
      setVar('--player-y', `${70 * (1 - playerEnter)}px`);
      setVar('--screen-opacity', String(screenEnter));
      setVar('--screen-scale', String(lerp(.84, 1, screenEnter)));
      setVar('--char-opacity', String(characterEnter * (.72 + (.28 * characterSettle))));
      setVar('--char1-x', `${lerp(char1ManifestX, char1ScreenX, characterSettle)}vw`);
      setVar('--char1-y', `${lerp(55, char1ScreenY, characterSettle)}vh`);
      setVar('--char2-x', `${lerp(42, char2ScreenX, characterSettle)}vw`);
      setVar('--char2-y', `${lerp(char2ManifestY, char2ScreenY, characterSettle)}vh`);
      setVar('--char3-x', `${lerp(char3ManifestX, char3ScreenX, characterSettle)}vw`);
      setVar('--char3-y', `${lerp(54, char3ScreenY, characterSettle)}vh`);
      setVar('--char1-scale', String(lerp(1, .66, characterSettle)));
      setVar('--char2-scale', String(lerp(1, .72, characterSettle)));
      setVar('--char3-scale', String(lerp(1, .66, characterSettle)));
    };

    const requestRender = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(renderStory);
      }
    };

    const revealTargets = document.querySelectorAll('.game-mosaic, .adventure-line');
    if (reduced.matches || !('IntersectionObserver' in window)) {
      revealTargets.forEach((target) => target.classList.add('is-in-view'));
    } else {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: .14, rootMargin: '0px 0px -10% 0px' });
      revealTargets.forEach((target) => observer.observe(target));
    }

    window.addEventListener('scroll', requestRender, { passive: true });
    window.addEventListener('resize', requestRender, { passive: true });
    desktop.addEventListener?.('change', requestRender);
    renderStory();
  })();
</script>
<style>
  .block { padding-top: 46px; }
  .last { padding-bottom: 56px; }
  .clamp2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .clamp3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .badge { background: var(--lime); color: var(--on-lime); font: 700 10px var(--mono); padding: 3px 9px; border-radius: 2px; }
  .meta { font: 400 10px var(--mono); color: var(--tx-dim); }
  .row-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

  /* Hero showcase */
  .home-hero { position: relative; min-height: max(720px, 100svh); margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 140px max(48px, calc((100vw - 1280px) / 2 + 48px)) 110px; border-bottom: 1px solid var(--bd-divider); isolation: isolate; }
  .hh-media, .hh-video, .hh-vignette, .hh-grid, .hh-noise { position: absolute; inset: 0; }
  .hh-media { z-index: -1; background: #050506; }
  .hh-video { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: saturate(.84) contrast(1.08) brightness(.68); }
  .hh-vignette { background: linear-gradient(90deg, rgba(5,5,6,.9) 0%, rgba(5,5,6,.38) 55%, rgba(5,5,6,.14) 76%, rgba(5,5,6,.5) 100%), linear-gradient(0deg, #070708 0%, transparent 36%, rgba(4,4,5,.5) 100%); }
  .hh-grid { opacity: .1; background-image: linear-gradient(rgba(255,255,255,.14) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.14) 1px, transparent 1px); background-size: 78px 78px; mask-image: linear-gradient(90deg, #000, transparent 72%); }
  .hh-noise { opacity: .16; background-image: radial-gradient(circle at 20% 30%, rgba(200,240,60,.34) 0 1px, transparent 1.5px), radial-gradient(circle at 70% 60%, rgba(255,255,255,.24) 0 1px, transparent 1.5px); background-size: 37px 41px, 53px 47px; mix-blend-mode: screen; }
  .hh-copy { position: relative; z-index: 2; width: min(1120px, 92vw); margin: 0 auto; text-align: center; }
  .hh-title { display: flex; flex-direction: column; align-items: center; font: 900 clamp(82px, 10vw, 154px)/.78 var(--display); letter-spacing: clamp(-8px, -.48vw, -4px); text-transform: uppercase; }
  .hh-title span { display: block; }
  .hh-title em { font-style: normal; font-weight: 900; }
  .hh-outline-white, .hh-outline-lime { color: transparent; }
  .hh-outline-white { -webkit-text-stroke: 2px rgba(255,255,255,.94); }
  .hh-outline-lime { -webkit-text-stroke: 2px var(--lime); }
  .hh-lime { color: var(--lime); text-shadow: 0 0 52px rgba(200,240,60,.2); }
  .hh-footer { position: absolute; z-index: 2; left: max(48px, calc((100vw - 1280px) / 2 + 48px)); right: max(48px, calc((100vw - 1280px) / 2 + 48px)); bottom: 34px; display: flex; justify-content: space-between; align-items: flex-end; }
  .hh-stats { display: flex; gap: 30px; color: rgba(255,255,255,.44); font: 400 9px var(--mono); letter-spacing: .7px; }
  .hh-stats span { display: flex; align-items: baseline; gap: 7px; }
  .hh-stats b { color: #fff; font: 900 16px var(--display); }
  .hh-scroll { display: flex; align-items: center; gap: 14px; color: rgba(255,255,255,.48); font: 700 8px var(--mono); letter-spacing: 1.5px; writing-mode: vertical-rl; }
  .hh-scroll:hover { color: var(--lime); }
  .hh-scroll i { width: 1px; height: 42px; background: linear-gradient(var(--lime), transparent); }

  /* Scroll-driven manifesto to Player One choreography */
  .story-sequence { position: relative; height: 360vh; margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); background: #060607; border-bottom: 1px solid var(--bd-divider); }
  .story-sticky { --manifest-left-x: -82vw; --manifest-right-x: 82vw; --manifest-opacity: 0; --player-opacity: 0; --player-y: 70px; --char-opacity: 0; --char1-x: -30vw; --char1-y: 55vh; --char2-x: 42vw; --char2-y: -38vh; --char3-x: 110vw; --char3-y: 54vh; --char1-scale:1; --char2-scale:1; --char3-scale:1; --screen-opacity:0; --screen-scale:.84; position: sticky; top: 0; height: 100vh; min-height: 680px; overflow: hidden; background: #060607; isolation: isolate; }
  .story-backgrounds, .story-bg, .story-bg-shade { position: absolute; inset: 0; }
  .story-backgrounds { z-index: -4; overflow: hidden; background: #060607; }
  .story-bg { width: 100%; height: 100%; object-fit: cover; pointer-events: none; }
  .story-bg-manifesto { opacity: .27; filter: saturate(.7) contrast(1.06) brightness(.66); }
  .story-bg-player { opacity: calc(var(--player-opacity) * .35); filter: saturate(.52) contrast(1.08) brightness(.58); transition: opacity .24s linear; }
  .story-bg-shade { background: linear-gradient(90deg, rgba(5,5,7,.78), rgba(5,5,7,.3) 48%, rgba(5,5,7,.72)), linear-gradient(0deg, rgba(5,5,7,.86), transparent 45%, rgba(5,5,7,.62)); }
  .story-grid { position: absolute; inset: 0; z-index: -2; opacity: .08; background: radial-gradient(circle at 50% 50%, rgba(200,240,60,.12), transparent 48%), linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px); background-size: auto, 96px 96px, 96px 96px; }
  .story-manifesto, .story-player { position: absolute; inset: 0; padding: 82px max(48px, calc((100vw - 1280px) / 2 + 48px)); }
  .story-manifesto { z-index: 3; display: flex; align-items: center; justify-content: center; pointer-events: none; }
  .manifesto-copy { position: relative; z-index: 3; display: flex; width: min(66vw, 980px); margin: 0 auto; flex-direction: column; align-items: center; justify-content: center; gap: 34px; text-align: center; text-transform: uppercase; }
  .manifesto-line { display: flex; width: max-content; max-width: 100%; margin: 0; flex-direction: column; align-items: center; opacity: var(--manifest-opacity); transition: transform .2s linear, opacity .2s linear; will-change: transform, opacity; }
  .manifesto-line-left { color: #fff; transform: translate3d(var(--manifest-left-x), 0, 0); }
  .manifesto-line-right { transform: translate3d(var(--manifest-right-x), 0, 0); }
  .manifesto-lead { font: 900 clamp(38px, 4vw, 60px)/.86 var(--display); letter-spacing: clamp(-4px, -.25vw, -2px); text-shadow: 0 3px 24px rgba(5,5,7,.92); }
  .manifesto-outline { display: block; font: 900 clamp(76px, 7.5vw, 116px)/.78 var(--display); letter-spacing: clamp(-8px, -.5vw, -4px); color: transparent; filter: drop-shadow(0 4px 12px rgba(0,0,0,.9)); }
  .manifesto-outline-white { -webkit-text-stroke: 2px rgba(255,255,255,.92); }
  .manifesto-outline-lime { -webkit-text-stroke: 2px var(--lime); filter: drop-shadow(0 4px 12px rgba(0,0,0,.9)) drop-shadow(0 0 28px rgba(200,240,60,.12)); }
  .story-characters { position: absolute; inset: 0; z-index: 2; pointer-events: none; }
  .story-char { position: absolute; top: 0; left: 0; opacity: var(--char-opacity); transform-origin: top left; transition: transform .3s cubic-bezier(.22,.61,.36,1), opacity .22s linear; will-change: transform, opacity; filter: drop-shadow(0 24px 42px rgba(0,0,0,.7)); }
  .story-char img { width: 100%; height: auto; object-fit: contain; animation: characterFloat 6.4s ease-in-out infinite; }
  .story-char-1 { width: min(18vw, 290px); transform: translate3d(var(--char1-x), var(--char1-y), 0) scale(var(--char1-scale)) rotate(-2deg); }
  .story-char-2 { z-index: 3; width: min(16vw, 250px); transform: translate3d(var(--char2-x), var(--char2-y), 0) scale(var(--char2-scale)) rotate(1deg); }
  .story-char-2 img { animation-delay: -2.1s; }
  .story-char-3 { width: min(18vw, 290px); transform: translate3d(var(--char3-x), var(--char3-y), 0) scale(var(--char3-scale)) rotate(2deg); }
  .story-char-3 img { animation-delay: -4.1s; }
  @keyframes characterFloat { 0%, 100% { transform: translateY(0) rotate(.15deg); } 50% { transform: translateY(-9px) rotate(-.35deg); } }
  .story-console { position:absolute; top:50%; right:max(48px,calc((100vw - 1280px) / 2 + 48px)); z-index:1; width:min(42vw,620px); height:min(56vh,510px); opacity:var(--screen-opacity); transform:translate3d(0,-44%,0) scale(var(--screen-scale)); transform-origin:center; transition:opacity .25s linear,transform .25s linear; will-change:opacity,transform; pointer-events:none; }
  .story-screen { position:absolute; inset:0 0 54px; overflow:hidden; border:2px solid rgba(200,240,60,.5); border-radius:18px; background:radial-gradient(circle at 50% 45%,rgba(200,240,60,.12),transparent 44%),linear-gradient(145deg,rgba(18,24,20,.88),rgba(3,5,5,.94)); box-shadow:0 34px 90px rgba(0,0,0,.56),0 0 42px rgba(200,240,60,.08),inset 0 0 50px rgba(0,0,0,.5); }
  .story-screen::before { content:''; position:absolute; inset:8px; border:1px solid rgba(255,255,255,.1); border-radius:11px; }
  .story-screen::after { content:''; position:absolute; inset:0; background:repeating-linear-gradient(180deg,transparent 0 5px,rgba(255,255,255,.018) 6px); mix-blend-mode:screen; }
  .story-screen-grid { position:absolute; inset:0; opacity:.18; background-image:linear-gradient(rgba(200,240,60,.12) 1px,transparent 1px),linear-gradient(90deg,rgba(200,240,60,.12) 1px,transparent 1px); background-size:48px 48px; mask-image:radial-gradient(circle at 50% 48%,#000,transparent 76%); }
  .story-screen-status { position:absolute; left:24px; top:22px; color:var(--lime); font:700 8px var(--mono); letter-spacing:1.6px; }
  .story-screen strong { position:absolute; right:24px; bottom:22px; color:rgba(255,255,255,.1); font:900 clamp(42px,5vw,74px)/.78 var(--display); letter-spacing:-4px; text-align:right; }
  .story-controller { position:absolute; left:50%; bottom:0; width:210px; height:72px; transform:translateX(-50%); border:1px solid rgba(255,255,255,.22); border-radius:38px 38px 24px 24px; background:linear-gradient(180deg,#202426,#090b0c); box-shadow:0 18px 38px rgba(0,0,0,.5); }
  .story-controller::before,.story-controller::after { content:''; position:absolute; top:19px; width:22px; height:22px; border-radius:50%; border:1px solid rgba(255,255,255,.26); background:#080909; }
  .story-controller::before { left:44px; } .story-controller::after { right:44px; }
  .story-controller i,.story-controller b { position:absolute; background:rgba(255,255,255,.34); }
  .story-controller i { left:92px; top:21px; width:26px; height:6px; } .story-controller b { left:102px; top:11px; width:6px; height:26px; }
  .story-controller em,.story-controller span { position:absolute; top:29px; width:7px; height:7px; border-radius:50%; background:var(--lime); box-shadow:0 0 10px rgba(200,240,60,.48); }
  .story-controller em { right:78px; } .story-controller span { right:65px; top:18px; }
  .story-player { z-index: 4; display: flex; align-items: center; opacity: var(--player-opacity); transform: translate3d(0, var(--player-y), 0); transition: transform .2s linear, opacity .2s linear; will-change: transform, opacity; pointer-events: none; }
  .story-player-copy { width: min(36vw, 520px); }
  .story-player-label { color: #fff; font: 900 clamp(44px, 4.7vw, 72px)/.82 var(--display); letter-spacing: clamp(-4px, -.26vw, -2px); }
  .story-player h2 { margin-top: 14px; color: transparent; font: 900 clamp(88px, 9.4vw, 142px)/.7 var(--display); letter-spacing: clamp(-9px, -.5vw, -5px); -webkit-text-stroke: 2px var(--lime); filter: drop-shadow(0 0 32px rgba(200,240,60,.13)); }
  .story-profile-link { pointer-events: auto; display: inline-flex; align-items: center; justify-content: space-between; gap: 48px; min-width: 218px; margin-top: 42px; padding: 14px 16px; border: 1px solid rgba(200,240,60,.62); background: rgba(7,7,8,.4); color: #fff; font: 700 10px var(--mono); letter-spacing: .8px; backdrop-filter: blur(10px); transition: background .25s ease, color .25s ease, transform .25s ease; }
  .story-profile-link span { color: var(--lime); }
  .story-profile-link:hover { background: var(--lime); color: #080809; transform: translateY(-2px); }
  .story-profile-link:hover span { color: #080809; }
  /* Selected games mosaic */
  .selected-worlds { margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); padding: 106px max(0px, calc((100vw - 1280px) / 2)) 120px; overflow: hidden; background: #0d0d0f; border-bottom: 1px solid var(--bd-divider); }
  .sw-head { display: flex; justify-content: center; margin-bottom: 48px; text-align: center; }
  .sw-head h2 { font: 900 clamp(62px, 7.4vw, 112px)/.82 var(--display); letter-spacing: clamp(-7px, -.4vw, -3px); text-transform: uppercase; }
  .sw-head h2 span { display: block; }
  .sw-head h2 em, .sw-head h2 strong { font-style: normal; font-weight: 900; }
  .sw-outline-white, .sw-outline-lime { color: transparent; }
  .sw-outline-white { -webkit-text-stroke: 1.8px rgba(255,255,255,.92); }
  .sw-outline-lime { -webkit-text-stroke: 1.8px var(--lime); }
  .sw-head h2 strong { color: var(--lime); text-shadow: 0 0 34px rgba(200,240,60,.14); }
  .game-mosaic { display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); grid-template-rows: 260px 260px 280px; gap: 12px; }
  .game-panel { position: relative; overflow: hidden; color: #fff; background: #151518; border: 1px solid rgba(255,255,255,.09); opacity: 0; transition: transform 1.05s cubic-bezier(.16,1,.3,1), opacity .7s ease, border-color .3s ease; isolation: isolate; }
  .game-panel:nth-child(odd) { transform: translate3d(-34vw, 0, 0) rotate(-1.2deg); }
  .game-panel:nth-child(even) { transform: translate3d(34vw, 0, 0) rotate(1.2deg); }
  .game-mosaic.is-in-view .game-panel { opacity: 1; transform: translate3d(0,0,0) rotate(0); }
  .game-mosaic.is-in-view .game-panel:nth-child(2) { transition-delay: .08s; }
  .game-mosaic.is-in-view .game-panel:nth-child(3) { transition-delay: .14s; }
  .game-mosaic.is-in-view .game-panel:nth-child(4) { transition-delay: .2s; }
  .game-mosaic.is-in-view .game-panel:nth-child(5) { transition-delay: .26s; }
  .game-mosaic.is-in-view .game-panel:nth-child(6) { transition-delay: .32s; }
  .game-mosaic.is-in-view .game-panel:nth-child(7) { transition-delay: .38s; }
  .game-panel-1 { grid-column: 1 / 8; grid-row: 1 / 3; }
  .game-panel-2 { grid-column: 8 / 13; grid-row: 1; }
  .game-panel-3 { grid-column: 8 / 13; grid-row: 2; }
  .game-panel-4 { grid-column: 1 / 4; grid-row: 3; }
  .game-panel-5 { grid-column: 4 / 7; grid-row: 3; }
  .game-panel-6 { grid-column: 7 / 10; grid-row: 3; }
  .game-panel-7 { grid-column: 10 / 13; grid-row: 3; }
  .game-panel > img { position: absolute; inset: 0; z-index: -2; width: 100%; height: 100%; object-fit: cover; filter: saturate(.78) contrast(1.05); transition: transform .9s cubic-bezier(.2,.7,.2,1), filter .5s ease; }
  .gp-shade { position: absolute; inset: 0; z-index: -1; background: linear-gradient(0deg, rgba(5,5,6,.38), transparent 46%); }
  .game-panel:hover { border-color: var(--lime-40); }
  .game-panel:hover > img { transform: scale(1.055); filter: saturate(1) contrast(1.03); }

  /* Statement before editorial content */
  .adventure-line { position: relative; min-height: 570px; margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); overflow: hidden; display: flex; align-items: center; justify-content: center; padding: 92px max(48px, calc((100vw - 1280px) / 2 + 48px)); background: #070708; border-bottom: 1px solid var(--bd-divider); isolation: isolate; }
  .adventure-line::before { content: ''; position: absolute; inset: -8%; z-index: -2; background: url('/images/showcase/hero-poster.webp') center 42% / cover no-repeat; filter: saturate(.45) blur(2px); opacity: .23; transform: scale(1.04); }
  .adventure-line::after { content: ''; position: absolute; inset: 0; z-index: -1; background: radial-gradient(circle at 50% 50%, rgba(200,240,60,.06), transparent 45%), linear-gradient(90deg, rgba(5,5,6,.9), rgba(5,5,6,.58), rgba(5,5,6,.9)); }
  .adventure-line h2 { width: 100%; font: 900 clamp(62px, 7.7vw, 118px)/.76 var(--display); letter-spacing: clamp(-7px, -.42vw, -3px); text-align: center; text-transform: uppercase; }
  .adventure-line h2 span { display: block; opacity: 0; transition: transform 1.3s cubic-bezier(.16,1,.3,1), opacity .9s ease; }
  .adventure-where { color: #fff; transform: translateX(-32vw); }
  .adventure-outline { margin-top: 12px; color: transparent; -webkit-text-stroke: 2px var(--lime); transform: translateX(32vw); }
  .adventure-fill { margin-top: 12px; color: var(--lime); text-shadow: 0 0 34px rgba(200,240,60,.16); transform: translateY(70px); }
  .adventure-line.is-in-view h2 span { opacity: 1; transform: translate3d(0,0,0); }
  .adventure-line.is-in-view .adventure-outline { transition-delay: .1s; }
  .adventure-line.is-in-view .adventure-fill { transition-delay: .2s; }
  /* Divider between editorial and news */
  .life-banner { position: relative; min-height: 260px; margin: 70px calc(-50vw + 50%) 16px; overflow: hidden; display: flex; align-items: center; justify-content: center; border-block: 1px solid rgba(255,255,255,.14); isolation: isolate; }
  .life-banner-art { position: absolute; inset: -12%; z-index: -2; background: linear-gradient(90deg, rgba(5,5,6,.92), rgba(5,5,6,.35) 48%, rgba(5,5,6,.86)), url('/images/showcase/games/crimson-desert.webp') center 48% / cover no-repeat; filter: saturate(.72) contrast(1.12); animation: bannerDrift 14s ease-in-out infinite alternate; }
  .life-banner::after { content: ''; position: absolute; inset: 0; z-index: -1; background: linear-gradient(0deg, rgba(5,5,6,.7), transparent 50%, rgba(5,5,6,.64)); }
  .life-banner h2 { display: flex; padding: 0 28px; flex-wrap: wrap; align-items: center; justify-content: center; gap: .12em .3em; color: #fff; font: 900 clamp(42px, 5.7vw, 86px)/.9 var(--display); letter-spacing: clamp(-6px, -.35vw, -2px); text-align: center; text-transform: uppercase; }
  .life-phrase { display: inline-flex; align-items: baseline; gap: .13em; white-space: nowrap; }
  .life-banner h2 strong, .life-banner h2 em { font-style: normal; font-weight: 900; }
  .life-outline-white, .life-outline-lime { color: transparent; }
  .life-outline-white { -webkit-text-stroke: 1.8px rgba(255,255,255,.94); }
  .life-lime { color: var(--lime); }
  .life-outline-lime { -webkit-text-stroke: 1.8px var(--lime); }
  @keyframes bannerDrift { from { transform: scale(1.04) translate3d(-1.5%,0,0); } to { transform: scale(1.12) translate3d(1.5%,-1.2%,0); } }
  /* Tier-list 3 boards */
  .tl3-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .tl3-card { border: 1px solid var(--bd-card); border-radius: 4px; overflow: hidden; background: var(--surface); color: #fff; display: flex; flex-direction: column; }
  .tl3-card:hover { border-color: var(--lime-40); }
  .tl3-art { position: relative; aspect-ratio: 16 / 8; }
  .tl3-art :global(.tl3-img) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tl3-badge-tag { position: absolute; top: 10px; left: 10px; background: var(--lime); color: var(--on-lime); font: 700 9px var(--mono); letter-spacing: 1px; padding: 3px 8px; border-radius: 2px; }
  .tl3-body { padding: 16px 16px 14px; display: flex; flex-direction: column; gap: 12px; }
  .tl3-top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .tl3-name { font: 900 18px var(--display); }
  .tl3-card:hover .tl3-name { color: var(--lime); }
  .tl3-meta { font: 400 9px var(--mono); color: var(--tx-meta); white-space: nowrap; }
  .tl3-preview { display: flex; flex-direction: column; gap: 5px; }
  .tl3-row { display: flex; gap: 6px; align-items: stretch; }
  .tl3-badge { width: 30px; flex: none; color: var(--on-lime); font: 900 12px var(--display); border-radius: 2px; display: flex; align-items: center; justify-content: center; }
  .tl3-track { flex: 1; background: var(--surface-2); border: 1px solid var(--bd-soft); border-radius: 2px; padding: 4px 6px; display: flex; gap: 4px; flex-wrap: wrap; align-items: center; min-height: 34px; }
  .tl3-ava { width: 26px; height: 26px; flex: none; border-radius: 2px; overflow: hidden; background: linear-gradient(145deg, #f3ddf0 0%, #dde6fb 55%, #dbf1e7 100%); display: flex; align-items: center; justify-content: center; }
  .tl3-ava img { width: 100%; height: 100%; object-fit: cover; }
  .tl3-ab { font: 700 7px var(--mono); color: rgba(24, 24, 34, 0.5); }
  .tl3-empty { font: 400 9px var(--mono); color: var(--tx-faint); }
  .tl3-cta { font: 700 10px var(--mono); color: var(--lime); margin-top: auto; }

  /* Featured news */
  .feat-news { display: grid; grid-template-columns: 1.5fr 1fr; gap: 16px; }
  .fn-lead { position: relative; border-radius: 4px; overflow: hidden; min-height: 360px; color: #fff; }
  .fn-lead :global(.fill) { position: absolute; inset: 0; width: 100%; height: 100%; }
  .fn-shade { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(10, 10, 11, 0.96) 0%, rgba(10, 10, 11, 0.4) 45%, transparent 72%); }
  .fn-lead-body { position: absolute; left: 26px; right: 26px; bottom: 24px; display: flex; flex-direction: column; gap: 10px; }
  .fn-lead-title { font: 900 30px/1.1 var(--display); letter-spacing: -0.5px; }
  .fn-lead:hover .fn-lead-title { color: var(--lime); }
  .fn-lead-dek { font: 400 12.5px/1.55 var(--display); color: var(--tx-65); max-width: 520px; margin: 0; }
  .fn-side { display: flex; flex-direction: column; gap: 14px; }
  .fn-small { display: flex; gap: 12px; color: #fff; border: 1px solid var(--bd-card); border-radius: 3px; overflow: hidden; background: var(--surface); flex: 1; }
  .fn-small :global(.fn-small-thumb) { width: 116px; flex: none; object-fit: cover; }
  .fn-small-body { padding: 12px 12px 12px 0; display: flex; flex-direction: column; gap: 6px; justify-content: center; }
  .fn-small-title { font: 800 14px/1.3 var(--display); }
  .fn-small:hover .fn-small-title { color: var(--lime); }
  .fn-small-meta { font: 400 9px var(--mono); color: var(--tx-faint); }

  /* 2-col Tin tức / Hướng dẫn */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .tc-col .sec-head { margin-bottom: 6px; }
  .li-list { display: flex; flex-direction: column; }
  .li-row { display: flex; gap: 16px; padding: 18px 0; border-bottom: 1px solid var(--bd-divider); color: #fff; }
  .li-row:last-child { border-bottom: none; }
  .li-row :global(.li-thumb) { width: 130px; height: 82px; border-radius: 3px; flex: none; object-fit: cover; }
  .li-body { display: flex; flex-direction: column; gap: 7px; justify-content: center; min-width: 0; }
  .li-title { font: 800 15px/1.3 var(--display); }
  .li-row:hover .li-title { color: var(--lime); }
  .li-dek { font: 400 11.5px/1.5 var(--display); color: var(--tx-dim); }
  .li-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag { background: rgba(255, 255, 255, 0.07); font: 400 9px var(--mono); padding: 3px 8px; border-radius: 2px; color: var(--tx-55); }
  .li-empty { font: 400 11px var(--mono); color: var(--tx-meta); padding: 16px 0; }

