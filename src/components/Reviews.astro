---
import Thumb from './Thumb.astro';

interface Item { slug: string; title: string; cover?: string | null; score?: number | string | null; review?: string | null }
interface Props { items: Item[]; heading?: string; note?: string; moreHref?: string; compact?: boolean; scroll?: boolean }
const { items, heading, note, moreHref, compact = false, scroll = false } = Astro.props;

const coverUrl = (slug: string, file?: string | null) => (file ? `/reviews/${slug}/${file}` : null);
const fmtScore = (s?: number | string | null) => {
  if (s === null || s === undefined || s === '') return '';
  const str = String(s).trim();
  return str.includes('/') ? str : `${str}/10`;
};
---

<section class:list={['gut', 'reviews-block', { compact, scrollx: scroll }]}>
  {heading && (
    <div class="sec-head">
      <div class="sec-title">{heading}</div>
      {note && <div class="sec-note">{note}</div>}
      {moreHref && <a class="sec-more" href={moreHref}>TẤT CẢ →</a>}
    </div>
  )}

  {items.length === 0 ? (
    <p class="rv-empty">Chưa có review nào.</p>
  ) : (
    <div class="rv-grid">
      {items.map((r) => (
        <button
          class="rv-card rvjs"
          data-title={r.title}
          data-score={fmtScore(r.score)}
          data-review={r.review ?? ''}
          data-img={coverUrl(r.slug, r.cover) ?? ''}
        >
          <div class="rv-art"><Thumb src={coverUrl(r.slug, r.cover)} label="key art" class="rv-img" /></div>
          <div class="rv-name">{r.title}</div>
          {fmtScore(r.score) && (
            <div class="rv-score-line">
              <span class="rv-lbl">CENIX CHẤM TẠM</span>
              <span class="rv-score">{fmtScore(r.score)}</span>
            </div>
          )}
        </button>
      ))}
    </div>
  )}
</section>

<div class="rv-popup" id="rv-popup" hidden>
  <div class="rv-modal">
    <button class="rv-close" id="rv-close" aria-label="Đóng">×</button>
    <div class="rv-modal-info">
      <div class="rv-kicker">◆ REVIEW NHANH</div>
      <div class="rv-modal-title" id="rv-m-title"></div>
      <div class="rv-modal-score">
        <span class="rv-lbl">CENIX CHẤM TẠM</span>
        <span class="rv-score" id="rv-m-score"></span>
      </div>
      <div class="rv-modal-review" id="rv-m-review"></div>
    </div>
    <div class="rv-modal-art"><img id="rv-m-img" alt="" /></div>
  </div>
</div>

<style>
  .reviews-block { padding-top: 44px; }
  .rv-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .reviews-block.compact .rv-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
  .rv-card { background: none; border: 0; padding: 0; cursor: pointer; text-align: left; color: #fff; display: flex; flex-direction: column; gap: 9px; }
  .rv-art { aspect-ratio: 3 / 4; border-radius: 4px; overflow: hidden; border: 1px solid var(--bd-card); }
  .rv-art :global(.rv-img) { width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s; }
  .rv-card:hover .rv-art :global(.rv-img) { transform: scale(1.04); }
  .rv-name { font: 800 14px/1.25 var(--display); }
  .rv-card:hover .rv-name { color: var(--lime); }
  .rv-score-line { display: flex; align-items: baseline; gap: 8px; }
  .rv-lbl { font: 400 8.5px var(--mono); letter-spacing: 1px; color: var(--tx-meta); text-transform: uppercase; }
  .rv-score { font: 900 15px var(--display); color: var(--lime); }
  .rv-empty { font: 400 12px var(--mono); color: var(--tx-meta); padding: 20px 0; }

  .rv-popup { position: fixed; inset: 0; z-index: 100; background: rgba(0, 0, 0, 0.72); display: flex; align-items: center; justify-content: center; padding: 20px; }
  .rv-popup[hidden] { display: none; }
  .rv-modal { position: relative; display: grid; grid-template-columns: 1fr 300px; gap: 0; width: min(760px, 100%); max-height: 90vh; background: var(--popup); border: 1px solid var(--bd-card); border-radius: 6px; overflow: hidden; }
  .rv-close { position: absolute; top: 10px; right: 12px; z-index: 2; width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--bd-chip); background: rgba(0, 0, 0, 0.4); color: #fff; font-size: 18px; line-height: 1; cursor: pointer; }
  .rv-close:hover { border-color: var(--lime); color: var(--lime); }
  .rv-modal-info { padding: 30px 30px 34px; display: flex; flex-direction: column; gap: 12px; overflow-y: auto; }
  .rv-kicker { font: 900 11px var(--mono); letter-spacing: 2px; color: var(--lime); }
  .rv-modal-title { font: 900 28px/1.1 var(--display); letter-spacing: -0.5px; }
  .rv-modal-score { display: flex; align-items: baseline; gap: 10px; }
  .rv-modal-score .rv-score { font: 900 26px var(--display); }
  .rv-modal-review { font: 400 13px/1.65 var(--display); color: var(--tx-65); white-space: pre-line; }
  .rv-modal-art { background: #111; }
  .rv-modal-art img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 900px) { .rv-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) {
    .reviews-block.scrollx .rv-grid { display: flex; overflow-x: auto; gap: 12px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 6px; grid-template-columns: none; }
    .reviews-block.scrollx .rv-card { width: 150px; flex: none; scroll-snap-align: start; }
  }
  @media (max-width: 760px) {
    .rv-modal { grid-template-columns: 1fr; max-height: 92vh; overflow-y: auto; }
    .rv-modal-art { aspect-ratio: 16 / 10; }
  }
  @media (max-width: 520px) { .rv-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<script>
  const popup = document.getElementById('rv-popup');
  const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  function open(btn) {
    set('rv-m-title', btn.dataset.title || '');
    set('rv-m-score', btn.dataset.score || '');
    const rev = btn.dataset.review || '';
    set('rv-m-review', rev);
    const img = document.getElementById('rv-m-img');
    const art = document.querySelector('.rv-modal-art');
    if (btn.dataset.img) { img.src = btn.dataset.img; art.style.display = ''; }
    else { art.style.display = 'none'; }
    document.getElementById('rv-m-score').parentElement.style.display = btn.dataset.score ? '' : 'none';
    popup.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  const close = () => { popup.hidden = true; document.body.style.overflow = ''; };
  document.querySelectorAll('.rvjs').forEach((b) => b.addEventListener('click', () => open(b)));
  document.getElementById('rv-close')?.addEventListener('click', close);
  popup?.addEventListener('click', (e) => { if (e.target === popup) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !popup.hidden) close(); });
</script>
