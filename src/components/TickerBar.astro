---
import { dmy } from '../lib/format';

interface Props {
  badge?: string;
  headline?: string;
}
const {
  badge = 'MỚI',
  headline = 'Bản 2.5 ra mắt — tổng hợp banner & code mới nhất',
} = Astro.props;

const now = new Date();
const weekdays = ['CHỦ NHẬT', 'THỨ HAI', 'THỨ BA', 'THỨ TƯ', 'THỨ NĂM', 'THỨ SÁU', 'THỨ BẢY'];
const dayLabel = `${weekdays[now.getDay()]}, ${dmy(now)}`;
---

<div class="ticker gut">
  <span class="badge">{badge}</span>
  <span class="headline">{headline}</span>
  <span class="date">{dayLabel}</span>
  <span class="clock" id="vn-clock">VN · --:--</span>
</div>

<style>
  .ticker {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 9px;
    padding-bottom: 9px;
    border-bottom: 1px solid var(--bd-divider);
    font: 400 10.5px var(--mono);
    color: var(--tx-dim);
  }
  .badge {
    background: var(--lime);
    color: var(--on-lime);
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 2px;
  }
  .headline { color: var(--tx-65); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .date { margin-left: auto; white-space: nowrap; }
  .clock { color: var(--lime); white-space: nowrap; }
  @media (max-width: 640px) { .date { display: none; } }
</style>

<script>
  const el = document.getElementById('vn-clock');
  function tick() {
    if (!el) return;
    const parts = new Intl.DateTimeFormat('vi-VN', {
      timeZone: 'Asia/Ho_Chi_Minh',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).format(new Date());
    el.textContent = `VN · ${parts}`;
  }
  tick();
  setInterval(tick, 30000);
</script>
