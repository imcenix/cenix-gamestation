---
import { NAV, SITE } from '../config/site';
import type { NavKey } from '../config/site';

interface Props { activeNav?: NavKey }
const { activeNav = 'home' } = Astro.props;
---

<header class="site-nav" id="site-nav">
<div class="nav gut">
  <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
  <a href="/" class="brand" aria-label={SITE.name}>
    <img class="brand-logo" src="/images/Cenix-Game-Station-Logo.png" alt={SITE.name} width="231" height="60" />
  </a>

  <nav class="nav-menu" aria-label="Điều hướng chính">
    {NAV.map((item, i) => (
      <a href={item.href} class:list={['nav-link', { active: item.key === activeNav }]}>
        <span class="nl-flip">
          <span class="nl-row">{item.label}</span>
          <span class="nl-row" aria-hidden="true">{item.label}</span>
        </span>
        <sup class="nl-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</sup>
      </a>
    ))}
  </nav>

<div class="nav-actions">
    <a class:list={['profile-cta', 'follow', { active: activeNav === 'profile' }]} href="/profile">
      <svg class="profile-cta-border" viewBox="0 0 178 52" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <linearGradient id="profile-border-light" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#c8f03c" stop-opacity="0" />
            <stop offset="0.46" stop-color="#c8f03c" />
            <stop offset="0.72" stop-color="#ffffff" />
            <stop offset="1" stop-color="#c8f03c" stop-opacity="0" />
          </linearGradient>
        </defs>
        <rect x="1.5" y="1.5" width="175" height="49" rx="2" pathLength="100" />
      </svg>
      <span>Cenix Profile</span>
    </a>
    <a class="profile-mobile" href="/profile" aria-label="Cenix Profile">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="8" r="3.25"></circle>
        <path d="M5.75 19c.55-4.05 2.65-6.1 6.25-6.1s5.7 2.05 6.25 6.1"></path>
      </svg>
    </a>
  </div>
</div>
</header>

<style>
  .site-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 60;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
  }
  /* Trang có hero video full-bleed (home, profile) để nav trong suốt đè lên. */
  :global(body:not([data-page='home']):not([data-page='profile'])) .site-nav {
    background: rgba(10, 10, 11, 0.92);
    border-bottom-color: var(--bd-divider);
  }
  .site-nav.scrolled {
    background: rgba(10, 10, 11, 0.85);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border-bottom-color: var(--bd-divider);
  }
  .nav {
    max-width: var(--maxw); margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 11px;
    padding-bottom: 11px;
  }
  .brand { display: flex; align-items: center; gap: 11px; color: #fff; }
  .brand-logo { height: 60px; width: auto; display: block; }

  .nav-menu { display: flex; gap: 34px; }
  .nav-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 4px;
    font: 700 16px var(--display);
    letter-spacing: 0.5px;
    color: var(--tx-55);
    transition: color 0.2s ease;
  }
  .nl-flip { display: inline-flex; flex-direction: column; overflow: hidden; height: 1.25em; line-height: 1.25; }
  .nl-row { display: block; height: 1.25em; line-height: 1.25em; transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1); will-change: transform; }
  .nav-link:hover .nl-row, .nav-link:focus-visible .nl-row { transform: translateY(-100%); }
  .nl-num { font: 500 9px var(--mono); letter-spacing: 0.5px; color: var(--lime); opacity: 0.55; line-height: 1; padding-top: 2px; }
  .nav-link:hover .nl-num, .nav-link.active .nl-num { opacity: 1; }
  .nav-link:hover { color: #fff; }
  .nav-link.active { color: var(--lime); }

  .nav-actions { display: flex; align-items: center; gap: 12px; }
  .follow { white-space: nowrap; }
  .profile-cta {
    position: relative;
    display: inline-flex;
    min-width: 178px;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    overflow: visible;
    border: 2px solid rgba(200, 240, 60, .58);
    border-radius: 3px;
    background: transparent;
    color: #fff;
    box-shadow: 0 0 0 1px rgba(200, 240, 60, .06), inset 0 0 18px rgba(200, 240, 60, .025);
    font: 800 13px var(--display);
    letter-spacing: 1.1px;
    text-transform: uppercase;
    transition: color .28s ease, border-color .28s ease, box-shadow .28s ease, transform .28s ease;
  }
  .profile-cta-border {
    position: absolute;
    inset: -2px;
    width: calc(100% + 4px);
    height: calc(100% + 4px);
    overflow: visible;
    pointer-events: none;
    filter: drop-shadow(0 0 5px rgba(200, 240, 60, .7));
  }
  .profile-cta-border rect {
    fill: none;
    stroke: url(#profile-border-light);
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-dasharray: 18 82;
    vector-effect: non-scaling-stroke;
    animation: profile-border-run 3s linear infinite;
  }
  .profile-cta span {
    position: relative;
    z-index: 1;
    text-shadow: 0 0 16px rgba(200, 240, 60, .16);
  }
  .profile-cta:hover,
  .profile-cta:focus-visible,
  .profile-cta.active {
    color: var(--lime);
    border-color: rgba(200, 240, 60, .88);
    box-shadow: 0 0 24px rgba(200, 240, 60, .22), inset 0 0 20px rgba(200, 240, 60, .06);
    transform: translateY(-2px);
  }
  .profile-cta:hover .profile-cta-border rect,
  .profile-cta:focus-visible .profile-cta-border rect { animation-duration: 1.8s; }
  @keyframes profile-border-run { to { stroke-dashoffset: -100; } }
  .profile-mobile { display: none; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none; border: none; cursor: pointer;
    padding: 6px;
  }
  .nav-hamburger span { display: block; width: 20px; height: 2px; background: #fff; transition: 0.2s; }
  .nav-hamburger[aria-expanded='true'] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .nav-hamburger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  @media (max-width: 900px) {
.follow { display: none; }
    .nav {
      position: relative;
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr) 40px;
      align-items: center;
      gap: 8px;
    }
    .nav-hamburger { display: flex; grid-column: 1; justify-self: start; width: 40px; height: 40px; align-items: center; justify-content: center; padding: 0; }
    .brand { grid-column: 2; justify-self: center; min-width: 0; }
    .nav-actions { grid-column: 3; justify-self: end; }
    .profile-mobile {
      display: grid;
      width: 40px;
      height: 40px;
      place-items: center;
      border: 1px solid rgba(200,240,60,.72);
      border-radius: 50%;
      background: rgba(6,7,7,.48);
      color: var(--lime);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .profile-mobile svg { width: 22px; height: 22px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .nav-menu {
      position: absolute;
      left: 0; right: 0;
      top: 100%;
      flex-direction: column;
      gap: 0;
      background: var(--popup);
      border-bottom: 1px solid transparent;
      padding: 0 var(--gutter);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease, padding 0.25s ease, border-color 0.25s ease;
      z-index: 40;
    }

    .nav-menu.is-open { max-height: 320px; padding-top: 8px; padding-bottom: 8px; border-bottom-color: var(--bd-divider); }
    .nav-link { padding: 14px 0; border-bottom: 1px solid var(--bd-soft); }
    .nav-link.active { border-bottom-color: var(--bd-soft); color: var(--lime); }
  }
  @media (min-width: 901px) and (max-width: 1220px) {
    .nav-menu { gap: 20px; }
    .profile-cta { min-width: 158px; min-height: 48px; font-size: 12px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .profile-cta-border rect { animation: none; }
  }
  @media (max-width: 560px) { .brand-logo { height: 50px; } }
</style>

<script>
  const siteNav = document.getElementById('site-nav');
  const onScroll = () => siteNav?.classList.toggle('scrolled', window.scrollY > 40);
  onScroll(); window.addEventListener('scroll', onScroll, { passive: true });
  const btn = document.getElementById('nav-hamburger');
  const menu = document.querySelector('.nav-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open') ?? false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
