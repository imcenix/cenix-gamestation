---
import { NAV, SITE } from '../config/site';
import type { NavKey } from '../config/site';

interface Props { activeNav?: NavKey }
const { activeNav = 'home' } = Astro.props;
---

<header class="site-nav" id="site-nav">
<div class="nav gut">
  <a href="/" class="brand" aria-label={SITE.name}>
    <img class="brand-logo" src="/images/Cenix-Game-Station-Logo.png" alt={SITE.name} width="231" height="60" />
  </a>

  <nav class="nav-menu" aria-label="Điều hướng chính">
    {NAV.map((item, i) => (
      <a href={item.href} class:list={['nav-link', { active: item.key === activeNav }]}>
        <span class="nl-flip">
          <span class="nl-row">{item.label}</span>
          <span class="nl-row" aria-hidden="true">{item.label}</span>
        </span>
        <sup class="nl-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</sup>
      </a>
    ))}
  </nav>

  <div class="nav-actions">
    <span class="btn-lime follow" aria-disabled="true" title="Sắp có">Cenix Profile</span>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Mở menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</div>
</header>

<style>
  .site-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 60;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
  }
  :global(body:not([data-page='home'])) .site-nav {
    background: rgba(10, 10, 11, 0.92);
    border-bottom-color: var(--bd-divider);
  }
  .site-nav.scrolled {
    background: rgba(10, 10, 11, 0.85);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border-bottom-color: var(--bd-divider);
  }
  .nav {
    max-width: var(--maxw); margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 11px;
    padding-bottom: 11px;
  }
  .brand { display: flex; align-items: center; gap: 11px; color: #fff; }
  .brand-logo { height: 60px; width: auto; display: block; }

  .nav-menu { display: flex; gap: 34px; }
  .nav-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 4px;
    font: 700 16px var(--display);
    letter-spacing: 0.5px;
    color: var(--tx-55);
    transition: color 0.2s ease;
  }
  .nl-flip { display: inline-flex; flex-direction: column; overflow: hidden; height: 1.25em; line-height: 1.25; }
  .nl-row { display: block; height: 1.25em; line-height: 1.25em; transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1); will-change: transform; }
  .nav-link:hover .nl-row, .nav-link:focus-visible .nl-row { transform: translateY(-100%); }
  .nl-num { font: 500 9px var(--mono); letter-spacing: 0.5px; color: var(--lime); opacity: 0.55; line-height: 1; padding-top: 2px; }
  .nav-link:hover .nl-num, .nav-link.active .nl-num { opacity: 1; }
  .nav-link:hover { color: #fff; }
  .nav-link.active { color: var(--lime); }

  .nav-actions { display: flex; align-items: center; gap: 12px; }
  .follow { white-space: nowrap; cursor: default; user-select: none; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none; border: none; cursor: pointer;
    padding: 6px;
  }
  .nav-hamburger span { display: block; width: 20px; height: 2px; background: #fff; transition: 0.2s; }
  .nav-hamburger[aria-expanded='true'] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .nav-hamburger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  @media (max-width: 900px) {
    .follow { display: none; }
    .nav-hamburger { display: flex; }
    .nav-menu {
      position: absolute;
      left: 0; right: 0;
      top: 100%;
      flex-direction: column;
      gap: 0;
      background: var(--popup);
      border-bottom: 1px solid var(--bd-divider);
      padding: 8px var(--gutter);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
      z-index: 40;
    }
    .nav { position: relative; flex-wrap: wrap; }
    .nav-menu.is-open { max-height: 320px; }
    .nav-link { padding: 14px 0; border-bottom: 1px solid var(--bd-soft); }
    .nav-link.active { border-bottom-color: var(--bd-soft); color: var(--lime); }
  }
  @media (max-width: 560px) { .brand-logo { height: 50px; } }
</style>

<script>
  const siteNav = document.getElementById('site-nav');
  const onScroll = () => siteNav?.classList.toggle('scrolled', window.scrollY > 40);
  onScroll(); window.addEventListener('scroll', onScroll, { passive: true });
  const btn = document.getElementById('nav-hamburger');
  const menu = document.querySelector('.nav-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open') ?? false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
